@page "/staff/orders/{maDH:guid}"
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IOrderService OrderService
@inject blazor_frontend.Services.IDiscountService DiscountService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@inject blazor_frontend.Services.AuthState AuthState

<PageTitle>Chi tiết đơn hàng</PageTitle>

<div class="max-w-5xl mx-auto px-4 md:px-6 py-6">
    @if (isLoading)
    {
        <div class="rounded-2xl border border-gray-200 bg-white p-8 text-center text-gray-500">Đang tải...</div>
    }
    else if (order == null)
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 p-6 text-red-700">Đơn hàng không tìm thấy</div>
    }
    else
    {
        <div class="space-y-6">
            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">Đơn hàng #@order.MaDH.ToString()[..8]</h1>
                        <p class="mt-1 text-sm text-gray-500">Đặt lúc @order.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold @GetStatusClass(order.TrangThaiDH)">
                        @GetStatusText(order.TrangThaiDH)
                    </span>
                </div>

                <div class="mt-4 flex items-center justify-between gap-3 border-t border-gray-100 pt-4">
                    <button class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" @onclick="GoBack">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 19l-7-7 7-7" />
                        </svg>
                        Quay lại danh sách đơn hàng
                    </button>
                </div>

                <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4 text-sm">
                    <div class="rounded-xl bg-gray-50 p-4">
                        <div class="text-gray-500">Khách hàng</div>
                        <div class="mt-1 font-semibold text-gray-900">@order.HoTen</div>
                    </div>
                    <div class="rounded-xl bg-gray-50 p-4">
                        <div class="text-gray-500">Số điện thoại</div>
                        <div class="mt-1 font-semibold text-gray-900">@order.SoDienThoai</div>
                    </div>
                    <div class="rounded-xl bg-gray-50 p-4 md:col-span-2 xl:col-span-1">
                        <div class="text-gray-500">Địa chỉ giao</div>
                        <div class="mt-1 font-semibold text-gray-900">@order.DiaChiGiaoHang</div>
                    </div>
                    <div class="rounded-xl bg-gray-50 p-4">
                        <div class="text-gray-500">Mã giảm giá</div>
                        <div class="mt-1 font-semibold @(discountCode != null ? "text-green-600" : "text-gray-500")">
                            @(discountCode != null ? $"{discountCode} {(minOrderValue > 0 ? $"(Tối thiểu {minOrderValue?.ToString("N0")}đ)" : "")}" : "Không áp dụng")
                        </div>
                    </div>
                    <div class="rounded-xl bg-gray-50 p-4">
                        <div class="text-gray-500">Tổng tiền</div>
                        <div class="mt-1 font-semibold text-gray-900">@order.TongTien.ToString("N0")đ</div>
                    </div>
                </div>
            </div>

            <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                <div class="border-b border-gray-100 px-6 py-4">
                    <h2 class="text-lg font-semibold text-gray-900">Sản phẩm trong đơn</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
                            <tr>
                                <th class="px-6 py-4 font-semibold">Sản phẩm</th>
                                <th class="px-6 py-4 text-right font-semibold">Đơn giá</th>
                                <th class="px-6 py-4 text-center font-semibold">Số lượng</th>
                                <th class="px-6 py-4 text-right font-semibold">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var it in order.ChiTietDonHangs)
                            {
                                <tr>
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="h-12 w-12 flex-shrink-0 rounded-md overflow-hidden bg-gray-100 border border-gray-200">
                                            <img src="@(string.IsNullOrEmpty(it.Anh_LuuTru) ? "/images/placeholder.png" : it.Anh_LuuTru)" alt="@it.TenSP_LuuTru" class="h-full w-full object-cover" />
                                        </div>
                                        <div>
                                            <div class="font-semibold text-gray-900">@it.TenSP_LuuTru</div>
                                            <div class="mt-1 text-xs text-gray-500">@it.Mau_LuuTru • @it.KichCo_LuuTru</div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-right text-gray-700">@it.Gia_LuuTru.ToString("N0")đ</td>
                                    <td class="px-6 py-4 text-center text-gray-700">@it.SoLuong</td>
                                    <td class="px-6 py-4 text-right font-semibold text-gray-900">@(it.Gia_LuuTru * it.SoLuong).ToString("N0")đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid maDH { get; set; }

    private DonHangDto? order;
    private bool isLoading = true;
    private string? discountCode;
    private decimal? minOrderValue;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/account/signin?returnUrl=/staff/orders/" + maDH);
            return;
        }

        if (AuthState.Role != "ADMIN" && AuthState.Role != "STAFF")
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        try
        {
            order = await OrderService.GetOrderByIdAsync(maDH);
            if (order != null && order.MaGG.HasValue)
            {
                var discounts = await DiscountService.GetDiscountsAsync();
                var appliedDiscount = discounts.FirstOrDefault(d => d.MaGG == order.MaGG.Value);
                if (appliedDiscount != null)
                {
                    discountCode = appliedDiscount.MaCode;
                    minOrderValue = appliedDiscount.DonHangToiThieu;
                }
            }
        }
        catch
        {
            order = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/account/orders");
    }

    private static string NormalizeStatus(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "choxacnhan" => "pending",
            "dangxuly" => "processing",
            "danggiao" => "shipping",
            "hoantat" => "completed",
            "dahuy" => "cancelled",
            "pending" => "pending",
            "processing" => "processing",
            "shipping" => "shipping",
            "completed" => "completed",
            "cancelled" => "cancelled",
            _ => "pending"
        };
    }

    private static string GetStatusText(string status)
    {
        return NormalizeStatus(status) switch
        {
            "pending" => "Chờ xác nhận",
            "processing" => "Đang xử lý",
            "shipping" => "Đang giao",
            "completed" => "Hoàn tất",
            "cancelled" => "Đã hủy",
            _ => "Không rõ"
        };
    }

    private static string GetStatusClass(string status)
    {
        return NormalizeStatus(status) switch
        {
            "pending" => "border-amber-200 bg-amber-50 text-amber-700",
            "processing" => "border-blue-200 bg-blue-50 text-blue-700",
            "shipping" => "border-purple-200 bg-purple-50 text-purple-700",
            "completed" => "border-green-200 bg-green-50 text-green-700",
            "cancelled" => "border-red-200 bg-red-50 text-red-700",
            _ => "border-gray-200 bg-gray-50 text-gray-700"
        };
    }
}
