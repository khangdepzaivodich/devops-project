@page "/unauthorized"
@layout blazor_frontend.Layout.EmptyLayout
@inject NavigationManager NavigationManager

<div class="unauthorized-container">
    <div class="unauthorized-card">
        <div class="unauthorized-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
            </svg>
        </div>
        <h1>403</h1>
        <h2>Truy cập bị từ chối</h2>
        <p>Bạn không có quyền truy cập trang này. Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là lỗi.</p>
        <div class="unauthorized-actions">
            <button class="btn-home" @onclick="GoHome">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Về trang chủ
            </button>
            <button class="btn-signin" @onclick="GoSignIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/>
                    <line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Đăng nhập lại
            </button>
        </div>
    </div>
</div>

<style>
    .unauthorized-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        padding: 2rem;
    }

    .unauthorized-card {
        text-align: center;
        max-width: 480px;
        padding: 3rem 2.5rem;
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    }

    .unauthorized-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        color: #e74c3c;
        animation: pulse 2s ease-in-out infinite;
    }

    .unauthorized-icon svg {
        width: 100%;
        height: 100%;
    }

    .unauthorized-card h1 {
        font-size: 4rem;
        font-weight: 800;
        color: #e74c3c;
        margin: 0 0 0.25rem;
        line-height: 1;
    }

    .unauthorized-card h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0 0 1rem;
    }

    .unauthorized-card p {
        color: #7f8c8d;
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0 0 2rem;
    }

    .unauthorized-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .unauthorized-actions button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
    }

    .btn-home {
        background: #2c3e50;
        color: #fff;
    }

    .btn-home:hover {
        background: #1a252f;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(44, 62, 80, 0.3);
    }

    .btn-signin {
        background: transparent;
        color: #2c3e50;
        border: 2px solid #2c3e50 !important;
    }

    .btn-signin:hover {
        background: #2c3e50;
        color: #fff;
        transform: translateY(-1px);
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.05); opacity: 0.8; }
    }
</style>

@code {
    private void GoHome()
    {
        NavigationManager.NavigateTo("/", replace: true);
    }

    private void GoSignIn()
    {
        NavigationManager.NavigateTo("/account/signin", replace: true);
    }
}
