@page "/account/orders"
@layout blazor_frontend.Layout.AccountProfileLayout
@using System.Linq
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IOrderService orderService
@inject blazor_frontend.Services.IUserService userService
@inject blazor_frontend.Services.ICatalogService catalogService
@inject blazor_frontend.Services.IDiscountService discountService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject blazor_frontend.Services.AuthState AuthState

<PageTitle>Đơn hàng của tôi</PageTitle>

<div class="min-h-[80vh] flex items-start justify-center py-10">
    <div class="w-full max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- SIDEBAR -->
        <aside class="bg-white border border-gray-200 rounded-2xl p-4 h-fit lg:col-span-1">
            <h3 class="text-xs font-semibold text-gray-400 uppercase mb-4">Account</h3>

            <nav class="flex flex-col gap-1 text-sm">
                <a href="/account/profile"
                   class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                    Profile
                </a>

                <a href="/account/orders"
                   class="px-4 py-3 rounded-xl bg-blue-600 text-white font-medium">
                    Đơn hàng của tôi
                </a>

                <a href="/account/messages"
                   class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                    Messages
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="lg:col-span-3 space-y-4">
            <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">Đơn hàng của tôi</h1>
                        <p class="mt-1 text-sm text-gray-500">Theo dõi trạng thái và chi tiết đơn hàng đã đặt.</p>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="p-8 text-center text-gray-500">Đang tải đơn hàng...</div>
                }
                else if (!orders.Any())
                {
                    <div class="p-10 text-center">
                        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 text-gray-500 mb-4">
                            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 6h12l-2-6M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />
                            </svg>
                        </div>
                        <h2 class="text-lg font-semibold text-gray-900">Chưa có đơn hàng nào</h2>
                        <button class="mt-5 rounded-lg border border-gray-300 px-5 py-2.5 font-semibold text-gray-700 hover:bg-gray-50"
                                @onclick="@(() => Navigation.NavigateTo("/products"))">
                            Mua sắm ngay
                        </button>
                    </div>
                }
                else
                {
                    <div class="overflow-hidden rounded-xl border border-gray-100">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
                                    <tr>
                                        <th class="px-5 py-4 font-semibold">Đơn hàng</th>
                                        <th class="px-5 py-4 font-semibold">Ngày đặt</th>
                                        <th class="px-5 py-4 text-right font-semibold">Tổng tiền</th>
                                        <th class="px-5 py-4 text-center font-semibold">Trạng thái</th>
                                        <th class="px-5 py-4 text-center font-semibold">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var order in orders)
                                    {
                                        <tr class="hover:bg-gray-50/70">
                                            <td class="px-5 py-4 flex items-center gap-3">
                                                @if (order.ChiTietDonHangs != null && order.ChiTietDonHangs.Any())
                                                {
                                                    <div class="h-12 w-12 flex-shrink-0 rounded-md overflow-hidden bg-gray-100 border border-gray-200">
                                                        <img src="@(string.IsNullOrEmpty(order.ChiTietDonHangs[0].Anh_LuuTru) ? "/images/placeholder.png" : order.ChiTietDonHangs[0].Anh_LuuTru)" alt="@order.ChiTietDonHangs[0].TenSP_LuuTru" class="h-full w-full object-cover" />
                                                    </div>
                                                }
                                                <div>
                                                    <div class="font-semibold text-gray-900">#@order.MaDH.ToString().Substring(0,8)</div>
                                                    <div class="mt-1 text-xs text-gray-500">@GetItemSummary(order)</div>
                                                </div>
                                            </td>
                                            <td class="px-5 py-4 text-gray-600">@order.NgayDat.ToString("dd/MM/yyyy")</td>
                                            <td class="px-5 py-4 text-right font-semibold text-gray-900">@order.TongTien.ToString("N0")đ</td>
                                            <td class="px-5 py-4 text-center">
                                                <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold @GetStatusClass(order.TrangThaiDH)">
                                                    @GetStatusText(order.TrangThaiDH)
                                                </span>
                                            </td>
                                            <td class="px-5 py-4 text-center">
                                                <button class="text-blue-600 font-medium hover:underline"
                                                        @onclick="@(() => ViewDetails(order))">
                                                    Chi tiết
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </main>
    </div>
</div>

@if (showOrderModal && selectedOrder != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm">
        <div class="w-full max-w-3xl rounded-2xl bg-white shadow-xl flex flex-col max-h-[90vh]">
            <div class="flex items-center justify-between border-b px-6 py-4">
                <h3 class="text-xl font-bold text-gray-900">Chi tiết đơn hàng #@selectedOrder.MaDH.ToString().Substring(0,8)</h3>
                <button @onclick="CloseModal" class="rounded-lg p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-600">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="overflow-y-auto p-6 space-y-6">
                <!-- Status & Date -->
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between rounded-xl bg-gray-50 p-4 border border-gray-100">
                    <div>
                        <div class="text-sm text-gray-500">Ngày đặt: @selectedOrder.NgayDat.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold @GetStatusClass(selectedOrder.TrangThaiDH)">
                        @GetStatusText(selectedOrder.TrangThaiDH)
                    </span>
                </div>

                <!-- Products -->
                <div>
                    <h4 class="mb-3 font-semibold text-gray-900">Sản phẩm</h4>
                    <div class="space-y-3">
                        @if (selectedOrder.ChiTietDonHangs != null)
                        {
                            @foreach (var item in selectedOrder.ChiTietDonHangs)
                            {
                                <div class="flex items-center justify-between rounded-lg border border-gray-100 p-3">
                                    <div class="flex items-center gap-3">
                                        <div class="h-12 w-12 flex-shrink-0 rounded-md overflow-hidden bg-gray-100 border border-gray-200">
                                            <img src="@(string.IsNullOrEmpty(item.Anh_LuuTru) ? "/images/placeholder.png" : item.Anh_LuuTru)" alt="@item.TenSP_LuuTru" class="h-full w-full object-cover" />
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-900">@item.TenSP_LuuTru</div>
                                            <div class="text-sm text-gray-500">@item.Mau_LuuTru • @item.KichCo_LuuTru | SL: @item.SoLuong</div>
                                        </div>
                                    </div>
                                    <div class="font-semibold text-gray-900">@((item.Gia_LuuTru * item.SoLuong).ToString("N0"))đ</div>
                                </div>
                            }
                        }
                    </div>
                </div>
                
                <!-- Total -->
                <div class="flex flex-col gap-2 border-t pt-4">
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-500">Mã giảm giá:</span>
                        <span class="font-semibold @(discountCode != null ? "text-green-600" : "text-gray-500")">
                            @(discountCode != null ? $"{discountCode} {(minOrderValue > 0 ? $"(Tối thiểu {minOrderValue?.ToString("N0")}đ)" : "")}" : "Không áp dụng")
                        </span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="font-semibold text-gray-700">Tổng cộng:</span>
                        <span class="text-xl font-bold text-blue-600">@selectedOrder.TongTien.ToString("N0")đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<DonHangDto> orders = new();
    private bool isLoading = true;
    private DonHangDto? selectedOrder = null;
    private bool showOrderModal = false;
    private string? discountCode = null;
    private decimal? minOrderValue = null;

    private async Task ViewDetails(DonHangDto order)
    {
        selectedOrder = order;
        discountCode = null;
        minOrderValue = null;
        if (order.MaGG.HasValue)
        {
            var discounts = await discountService.GetDiscountsAsync();
            var appliedDiscount = discounts.FirstOrDefault(d => d.MaGG == order.MaGG.Value);
            if (appliedDiscount != null)
            {
                discountCode = appliedDiscount.MaCode;
                minOrderValue = appliedDiscount.DonHangToiThieu;
            }
        }
        showOrderModal = true;
    }

    private void CloseModal()
    {
        showOrderModal = false;
        selectedOrder = null;
        discountCode = null;
        minOrderValue = null;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/signin?returnUrl=/account/orders");
            return;
        }

        var userId = AuthState.UserId;

        try
        {
            var result = await orderService.GetOrdersByUserIdAsync(userId);
            orders = result.OrderByDescending(x => x.NgayDat).ToList();
        }
        catch { }
        finally { isLoading = false; }
    }

    private string GetItemSummary(DonHangDto order)
    {
        if (order.ChiTietDonHangs == null || !order.ChiTietDonHangs.Any()) return "Không có sản phẩm";
        var first = order.ChiTietDonHangs[0].TenSP_LuuTru;
        return order.ChiTietDonHangs.Count > 1 ? $"{first} (+{order.ChiTietDonHangs.Count - 1})" : first;
    }

    private string GetStatusText(string status) => status.ToLower() switch {
        "choxacnhan" or "pending" => "Chờ xác nhận",
        "dangxuly" or "processing" => "Đang xử lý",
        "danggiao" or "shipping" => "Đang giao",
        "hoantat" or "completed" => "Hoàn tất",
        "dahuy" or "cancelled" => "Đã hủy",
        _ => "Không rõ"
    };

    private string GetStatusClass(string status) => status.ToLower() switch {
        "choxacnhan" or "pending" => "border-amber-200 bg-amber-50 text-amber-700",
        "dangxuly" or "processing" => "border-blue-200 bg-blue-50 text-blue-700",
        "danggiao" or "shipping" => "border-purple-200 bg-purple-50 text-purple-700",
        "hoantat" or "completed" => "border-green-200 bg-green-50 text-green-700",
        "dahuy" or "cancelled" => "border-red-200 bg-red-50 text-red-700",
        _ => "border-gray-200 bg-gray-50 text-gray-700"
    };
}
