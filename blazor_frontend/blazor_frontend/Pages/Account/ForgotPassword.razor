@page "/account/forgot-password"
@layout blazor_frontend.Layout.AccountLayout
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IAuthService AuthService
@inject NavigationManager Nav
@inject blazor_frontend.Services.AuthState AuthState

<div class="space-y-4">
    <div class="text-center">
        <h1 class="text-2xl font-bold">Forgot Password</h1>
        <p class="text-sm text-gray-600">Enter your email and we'll send you a link to reset your password.</p>
    </div>

    @if (isSuccess)
    {
        <div class="p-4 rounded bg-green-50 text-green-700 border border-green-100">
            Check your email! We've sent a password reset link to <strong>@model.Email</strong>.
        </div>
        <div class="text-center mt-4">
            <a href="/account/signin" class="text-blue-700 hover:underline">Back to Sign in</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="p-3 rounded bg-red-50 text-red-700 border border-red-100">
                @errorMessage
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit" class="space-y-4">
            <DataAnnotationsValidator />

            <div>
                <label class="block text-sm text-gray-600 mb-1">Email address</label>
                <InputText class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" 
                           @bind-Value="model.Email" placeholder="name@example.com" />
                <ValidationMessage For="@(() => model.Email)" class="text-red-500 text-xs mt-1" />
            </div>

            <button type="submit" class="w-full bg-blue-700 text-white py-2 rounded-lg font-semibold hover:bg-blue-800 transition-colors" 
                    disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="inline-block animate-spin mr-2">↻</span>
                    <span>Processing...</span>
                }
                else
                {
                    <span>Send Reset Link</span>
                }
            </button>

            <div class="text-center text-sm">
                <a href="/account/signin" class="text-gray-500 hover:text-blue-700">Remember your password? Sign in</a>
            </div>
        </EditForm>
    }
</div>

@code {
    private ForgotPasswordRequest model = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool isSuccess;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.InitializeAsync();
        if (AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/", replace: true);
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.ForgotPasswordAsync(model);
            if (result)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = "Could not send reset link. Please verify your email or try again later.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
