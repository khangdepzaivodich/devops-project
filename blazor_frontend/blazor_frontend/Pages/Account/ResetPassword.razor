@page "/account/reset-password"
@page "/reset-password"
@layout blazor_frontend.Layout.AccountLayout
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IAuthService AuthService
@inject NavigationManager Nav
@inject blazor_frontend.Services.AuthState AuthState

<div class="space-y-4">
    <div class="text-center">
        <h1 class="text-2xl font-bold">Reset Password</h1>
        <p class="text-sm text-gray-600">Please enter your new password below.</p>
    </div>

    @if (isSuccess)
    {
        <div class="p-4 rounded bg-green-50 text-green-700 border border-green-100">
            Password reset successful! You can now sign in with your new password.
        </div>
        <div class="text-center mt-4">
            <a href="/account/signin" class="w-full inline-block bg-blue-700 text-white py-2 rounded-lg font-semibold text-center">Go to Sign in</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="p-3 rounded bg-red-50 text-red-700 border border-red-100">
                @errorMessage
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleReset" class="space-y-4">
            <DataAnnotationsValidator />

            <div>
                <label class="block text-sm text-gray-600 mb-1">New Password</label>
                <InputText type="password" class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" 
                           @bind-Value="model.NewPassword" />
                <ValidationMessage For="@(() => model.NewPassword)" class="text-red-500 text-xs mt-1" />
            </div>

            <button type="submit" class="w-full bg-blue-700 text-white py-2 rounded-lg font-semibold hover:bg-blue-800 transition-colors" 
                    disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="inline-block animate-spin mr-2">↻</span>
                    <span>Resetting...</span>
                }
                else
                {
                    <span>Update Password</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    private ResetPasswordRequest model = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool isSuccess;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    protected override void OnInitialized()
    {
        model.Email = Email ?? "";
        model.Token = Token ?? "";

        if (string.IsNullOrEmpty(model.Token))
        {
            errorMessage = "Invalid or expired reset link.";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.InitializeAsync();
        if (AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/", replace: true);
        }
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(model.Token)) return;

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await AuthService.ResetPasswordAsync(model);
            if (result)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = "Failed to reset password. The link may have expired.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
