@page "/account/messages"
@layout blazor_frontend.Layout.AccountProfileLayout
@using System.Text.Json
@using blazor_frontend.Models
@using blazor_frontend.Services
@inject IJSRuntime JS
@inject IChatService ChatService
@inject AuthState AuthState
@implements IDisposable

<div class="min-h-[80vh] flex items-start justify-center py-10">
    <div class="w-full max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- SIDEBAR -->
        <aside class="bg-white border border-gray-200 rounded-2xl p-4 h-fit lg:col-span-1">
            <h3 class="text-xs font-semibold text-gray-400 uppercase mb-4">Account</h3>

            <nav class="flex flex-col gap-1 text-sm">
                <a href="/account/profile"
                   class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                    Profile
                </a>

                <a href="/account/orders"
                   class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                    Đơn hàng của tôi
                </a>

                <a href="/account/messages"
                   class="px-4 py-3 rounded-xl bg-blue-600 text-white font-medium">
                    Messages
                </a>
            </nav>
        </aside>

        <!-- Main Chat Panel -->
        <main class="lg:col-span-3 bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden flex flex-col h-[700px]">
            <!-- Header Chat -->
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-white z-10 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-100 border-2 border-white shadow-md">
                        <img src="@(string.IsNullOrEmpty(staffAvatar) ? "https://ui-avatars.com/api/?name=Staff&background=0b3b72&color=fff" : staffAvatar)" alt="Support" class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 text-lg">@(string.IsNullOrEmpty(staffName) || staffName == "Administrator" ? "Nhân viên tư vấn" : $"Tư vấn viên: {staffName}")</h3>
                        <div class="flex items-center gap-1.5 mt-0.5">
                            <span class="w-2 h-2 rounded-full block bg-green-500"></span>
                            <span class="text-sm text-gray-500">Chúng tôi đang trực tuyến</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tin nhắn -->
            <div id="accountChatContainer" class="flex-1 overflow-y-auto p-6 flex flex-col gap-4 bg-gray-50/50 relative">
                @if (messages != null && messages.Any())
                {
                    @foreach (var msg in messages)
                    {
                        <div class="flex @(msg.IsMine ? "flex-row-reverse" : "flex-row") items-end gap-3 mb-2">
                            <div class="w-9 h-9 rounded-full overflow-hidden shrink-0 border-2 border-white shadow-sm bg-gray-100">
                                <img src="@(msg.IsMine ? (string.IsNullOrEmpty(AuthState.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(AuthState.HoTen ?? "User")}&background=random" : AuthState.AvatarUrl) : (string.IsNullOrEmpty(msg.Avatar) ? (string.IsNullOrEmpty(staffAvatar) ? "https://ui-avatars.com/api/?name=Staff&background=0b3b72&color=fff" : staffAvatar) : msg.Avatar))" 
                                     class="w-full h-full object-cover" />
                            </div>
                            <div class="max-w-[70%] flex flex-col @(msg.IsMine ? "items-end" : "items-start")">
                                <div class="px-4 py-2.5 shadow-sm text-[15px] @(msg.IsMine ? "bg-blue-600 text-white rounded-lg rounded-br-sm" : "bg-white border border-gray-200 text-gray-800 rounded-lg rounded-bl-sm") leading-relaxed whitespace-pre-wrap">
                                    @msg.Text
                                </div>
                                <span class="text-[11px] text-gray-400 mt-1">
                                    @msg.Timestamp.ToLocalTime().ToString("HH:mm")
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Ô nhập tin nhắn -->
            <div class="p-4 border-t border-gray-200 bg-white">
                <div class="flex items-center gap-3 bg-gray-50 p-2 rounded-xl border border-gray-200 focus-within:border-blue-500 transition-all">
                    <input type="text" @bind="newMessage" @onkeyup="HandleKeyUp" placeholder="Nhập tin nhắn..." class="flex-1 bg-transparent px-2 py-2 outline-none" />
                    <button @onclick="SendMessage" class="@(string.IsNullOrWhiteSpace(newMessage) ? "bg-gray-200" : "bg-blue-600 text-white") p-2.5 rounded-lg">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </div>
            </div>
        </main>
    </div>
</div>

@code {
    private string currentSessionId = "";
    private string staffName = "";
    private string staffAvatar = "";
    private string userAvatar = "";
    private string newMessage = "";
    private string hoTen = "";
    private List<ChatMessage> messages = new();

    protected override async Task OnInitializedAsync()
    {
        ChatService.OnMessageReceived += HandleMessageReceived;
        ChatService.OnSessionAssigned += HandleSessionAssigned;
        ChatService.OnStaffNameUpdated += HandleStaffNameUpdated;
        await ChatService.InitializeAsync();

        userAvatar = AuthState.AvatarUrl;
        hoTen = AuthState.HoTen;

        var session = await JS.InvokeAsync<string>("localStorage.getItem", "chat_session_id");
        var userId = AuthState.UserId;

        if (AuthState.IsAuthenticated)
        {
            // Bắt buộc xóa ID cũ để tránh dùng lại phiên khách
            await JS.InvokeVoidAsync("localStorage.removeItem", "chat_session_id");
            session = null;

            var serverSession = await ChatService.GetLatestActiveSessionAsync(userId.ToString());
            if (serverSession != null)
            {
                session = serverSession.Id.ToString();
                await JS.InvokeVoidAsync("localStorage.setItem", "chat_session_id", session);
            }
            else
            {
                session = await ChatService.CreateNewChatSessionAsync(userId.ToString(), "USER");
                if (!string.IsNullOrEmpty(session))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "chat_session_id", session);
                }
            }
        }

        if (!string.IsNullOrEmpty(session))
        {
            currentSessionId = session;
            await ChatService.JoinChatSessionAsync(currentSessionId);

            // Lấy thông tin phiên để lấy tên Staff
            var sessionInfo = await ChatService.GetChatSessionAsync(Guid.Parse(currentSessionId));
            if (sessionInfo != null)
            {
                staffName = sessionInfo.StaffHoTen;
                staffAvatar = sessionInfo.StaffAvatar;
                if (staffName == "Administrator") staffName = "Nhân viên tư vấn";
                StateHasChanged();
            }
            
            var history = await JS.InvokeAsync<string>("localStorage.getItem", $"chat_history_{currentSessionId}");
            if (string.IsNullOrEmpty(history))
            {
                // Lấy từ server nếu local trống
                var serverMsgs = await ChatService.GetChatHistoryAsync(Guid.Parse(currentSessionId));
                if (serverMsgs != null && serverMsgs.Any())
                {
                    messages = serverMsgs
                        .Where(m => !m.IsInternalNote)
                        .Select(m => new ChatMessage { 
                        Text = m.NoiDung, 
                        IsMine = m.SenderType == "USER" || m.SenderType == "GUEST",
                        Timestamp = m.ThoiGianGui 
                    }).ToList();
                    await SaveMessages();
                }
            }
            else
            {
                try { messages = JsonSerializer.Deserialize<List<ChatMessage>>(history) ?? new(); }
                catch { messages = new(); }
            }

            // Sync identity
            await TryUpgradeSession();
        }
        
        await Task.Delay(500);
        await ScrollToBottom();
    }

    private void HandleMessageReceived(blazor_frontend.Models.ChatMessageDto tinNhan)
    {
        if (tinNhan.IsInternalNote) return; // Khách không bao giờ được thấy internal note

        if (tinNhan.SenderType != "GUEST" && tinNhan.SenderType != "USER") // Chỉ nhận tin từ Staff/Bot
        {
            messages.Add(new ChatMessage { 
                Text = tinNhan.NoiDung, 
                IsMine = false, 
                Timestamp = tinNhan.ThoiGianGui,
                Avatar = tinNhan.SenderAvatar
            });
            _ = SaveMessages();
            InvokeAsync(() => {
                StateHasChanged();
                _ = ScrollToBottom();
            });
        }
    }

    private void HandleStaffNameUpdated(string newName)
    {
        InvokeAsync(() => {
            staffName = newName;
            StateHasChanged();
        });
    }

    private void HandleSessionAssigned(string sessionId, string staffId, string name)
    {
        InvokeAsync(() => {
            staffName = name == "Administrator" ? "Nhân viên tư vấn" : name;
            messages.Add(new ChatMessage { Text = $"Tư vấn viên {staffName} đã tham gia cuộc trò chuyện.", IsMine = false, Timestamp = DateTime.Now });
            StateHasChanged();
        });
    }

    private async Task TryUpgradeSession()
    {
        if (AuthState.IsAuthenticated)
        {
            await ChatService.UpgradeSessionAsync(currentSessionId, AuthState.UserId.ToString(), AuthState.HoTen);
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage)) return;

        var textToSend = newMessage.Trim();
        newMessage = "";

        messages.Add(new ChatMessage { Text = textToSend, IsMine = true, Timestamp = DateTime.Now, Avatar = userAvatar });
        await SaveMessages();
        StateHasChanged();
        await ScrollToBottom();

        if (ChatService.ConnectionState == Microsoft.AspNetCore.SignalR.Client.HubConnectionState.Connected && !string.IsNullOrWhiteSpace(currentSessionId))
        {
            bool isUser = AuthState.IsAuthenticated;

            var tn = new blazor_frontend.Models.ChatMessageDto
            {
                MaPhien = Guid.Parse(currentSessionId),
                SenderType = isUser ? "USER" : "GUEST",
                SenderID = isUser ? AuthState.UserId : Guid.Empty,
                SenderName = AuthState.IsAuthenticated ? AuthState.HoTen : "Khách",
                SenderAvatar = AuthState.AvatarUrl ?? "",
                NoiDung = textToSend,
                TrangThai = "sent"
            };

            await ChatService.SendMessageAsync(tn);
        }
    }

    private async Task SaveMessages()
    {
        var json = JsonSerializer.Serialize(messages);
        await JS.InvokeVoidAsync("localStorage.setItem", $"chat_history_{currentSessionId}", json);
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("scrollToBottomById", "accountChatContainer"); }
        catch { }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    public void Dispose()
    {
        ChatService.OnMessageReceived -= HandleMessageReceived;
        ChatService.OnSessionAssigned -= HandleSessionAssigned;
        ChatService.OnStaffNameUpdated -= HandleStaffNameUpdated;
    }

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsMine { get; set; }
        public DateTime Timestamp { get; set; }
        public string Avatar { get; set; } = "";
    }
}