@page "/admin/categories"
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.ICategoryService categoryService
@inject blazor_frontend.Services.IProductService productService
@inject SweetAlertService Swal
<PageTitle>Quản lý Danh mục</PageTitle>

<div class="bg-white rounded-xl shadow-sm w-full p-6 pb-12 min-h-[600px] flex flex-col">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Quản lý Danh mục</h2>
            <p class="text-sm text-gray-500 mt-1">Quản lý cơ cấu loại danh mục và danh mục sản phẩm.</p>
        </div>
        @if (activeTab == "danhmuc")
        {
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl transition-all flex items-center gap-2 shadow-sm hover:shadow-blue-200 active:scale-95" @onclick="NewDanh">
                <i class="ph ph-plus-circle text-xl"></i>
                Thêm danh mục
            </button>
        }
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-gray-100 mb-8">
        <button class="@(activeTab == "loaidanhmuc" ? "border-blue-600 text-blue-600" : "border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300") py-3 px-8 text-center border-b-2 font-bold text-sm transition-all flex items-center gap-2" @onclick='() => { activeTab = "loaidanhmuc"; CurrentPage = 1; }'>
            <i class="ph ph-folder text-xl"></i>
            Loại danh mục
        </button>
        <button class="@(activeTab == "danhmuc" ? "border-blue-600 text-blue-600" : "border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-300") py-3 px-8 text-center border-b-2 font-bold text-sm transition-all flex items-center gap-2" @onclick='() => { activeTab = "danhmuc"; CurrentPage = 1; }'>
            <i class="ph ph-tree-structure text-xl"></i>
            Danh mục
        </button>
    </div>

    @* Loại danh mục *@
    @if (activeTab == "loaidanhmuc")
    {
        <div class="bg-gray-50/50 border border-gray-100 rounded-2xl p-8 min-h-[300px] flex flex-col shadow-sm">
            <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900">Các Loại Danh Mục</h3>
                <p class="text-sm text-gray-400 mt-1">Phân loại cấp cao nhất của hệ thống.</p>
            </div>
            
            @if (itemsLoaiDanhMuc == null)
            {
                <div class="flex-1 flex flex-col items-center justify-center py-12 text-gray-400 font-medium">
                    <div class="inline-block h-10 w-10 animate-spin rounded-full border-4 border-solid border-blue-600 border-r-transparent mb-4"></div>
                    Đang tải dữ liệu...
                </div>
            }
            else
            {
                <div class="flex flex-wrap gap-4 items-center">
                    @if (!itemsLoaiDanhMuc.Any())
                    {
                        <div class="w-full text-center py-12 text-gray-400 italic">Chưa có loại danh mục nào</div>
                    }
                    
                    @foreach (var ldm in itemsLoaiDanhMuc)
                    {
                        <div class="group flex items-center bg-blue-50 border border-blue-100 text-blue-700 pl-4 pr-2 py-2 rounded-xl font-bold text-sm shadow-sm transition-all hover:shadow-md hover:border-blue-300 hover:-translate-y-0.5">
                            <i class="ph ph-folder-open mr-2 text-xl text-blue-500"></i>
                            <span class="mr-2 cursor-pointer" @onclick="() => EditLoai(ldm)">@ldm.TenLDM</span>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-red-50 text-blue-400 hover:text-red-600 transition-colors" title="Xóa" @onclick="() => DeleteLoai(ldm.MaLDM)">
                                <i class="ph ph-x-circle text-xl"></i>
                            </button>
                        </div>
                    }
                    
                    <button class="group flex items-center justify-center px-4 py-2 bg-white border-2 border-dashed border-gray-200 rounded-xl text-gray-400 hover:text-blue-600 hover:border-blue-400 hover:bg-blue-50 transition-all shadow-sm" title="Thêm loại danh mục" @onclick="NewLoai">
                        <i class="ph ph-plus-circle text-xl mr-2 group-hover:scale-110 transition-transform"></i>
                        <span class="text-sm font-bold tracking-tight">THÊM MỚI</span>
                    </button>
                </div>
            }
        </div>
    }
    @* Danh mục *@
    else if (activeTab == "danhmuc")
    {
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-end mb-8">
            <div class="flex flex-wrap items-center gap-3">
                <div class="relative group">
                    <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-lg group-focus-within:text-blue-500 transition-colors"></i>
                    <input type="text" @bind="searchDanh" @bind:event="oninput" 
                           class="rounded-xl border border-gray-100 pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all w-64 shadow-sm" 
                           placeholder="Tìm danh mục, slug...">
                </div>
                <div class="w-64 relative">
                    <i class="ph ph-filter absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <select @bind="filterMaLDM" class="w-full pl-10 pr-4 py-2.5 border border-gray-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 bg-white cursor-pointer shadow-sm text-sm text-gray-600 font-medium appearance-none">
                        <option value="@Guid.Empty">Tất cả loại danh mục</option>
                        @if (itemsLoaiDanhMuc != null)
                        {
                            @foreach(var ldm in itemsLoaiDanhMuc)
                            {
                                <option value="@ldm.MaLDM">@ldm.TenLDM</option>
                            }
                        }
                    </select>
                    <i class="ph ph-caret-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
            </div>
        </div>

        <div class="flex-1 overflow-x-auto border border-gray-50 rounded-xl shadow-sm custom-scrollbar">
            <table class="min-w-full text-left border-collapse bg-white table-auto">
                    <thead>
                        <tr class="bg-gray-50/50 text-gray-400 text-[11px] uppercase tracking-widest font-bold whitespace-nowrap">
                            <th class="p-4 border-b border-gray-50 w-1/3">Danh mục</th>
                            <th class="p-4 border-b border-gray-50 w-1/4">Phân loại gốc</th>
                            <th class="p-4 border-b border-gray-50 text-center">Số sản phẩm</th>
                            <th class="p-4 border-b border-gray-50 text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 text-sm">
                        @if (itemsDanhMuc == null)
                        {
                             <tr><td colspan="4" class="p-4 text-center py-20 font-medium text-gray-400">Đang tải dữ liệu...</td></tr>
                        }
                        else if (!PaginatedDanhMuc.Any())
                        {
                             <tr><td colspan="4" class="p-4 text-center py-20 text-gray-400 italic">Không tìm thấy danh mục nào</td></tr>
                        }
                        else
                        {
                            @foreach (var dm in PaginatedDanhMuc)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50/80 transition-colors">
                                    <td class="p-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-emerald-100 text-emerald-700 flex items-center justify-center">
                                                <i class="ph ph-tree-structure text-lg"></i>
                                            </div>
                                            <span class="font-bold text-gray-900">@dm.TenDM</span>
                                        </div>
                                    </td>
                                    <td class="p-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold bg-blue-100 text-blue-800 uppercase tracking-wider">
                                            @(itemsLoaiDanhMuc?.FirstOrDefault(x => x.MaLDM == dm.MaLDM)?.TenLDM ?? "Chưa xác định")
                                        </span>
                                    </td>
                                    <td class="p-4 text-center whitespace-nowrap">
                                        @{
                                            var pCount = GetProductCount(dm.MaDM);
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold @(pCount > 0 ? "bg-amber-50 text-amber-700" : "bg-gray-50 text-gray-400")">
                                                @pCount sản phẩm
                                            </span>
                                        }
                                    </td>
                                    <td class="p-4 text-right space-x-1">
                                        <button class="p-2 text-blue-600 hover:bg-blue-50 rounded-xl transition-all" @onclick="() => EditDanh(dm)" title="Sửa">
                                            <i class="ph ph-pencil-simple text-xl"></i>
                                        </button>
                                        <button class="p-2 text-red-600 hover:bg-red-50 rounded-xl transition-all" @onclick="() => DeleteDanh(dm.MaDM)" title="Xóa">
                                            <i class="ph ph-trash text-xl"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
        </div>

        <!-- Phân trang UI (Căn giữa chuẩn style) -->
        @if (itemsDanhMuc != null && TotalPages > 1)
        {
            <div class="mt-8 mb-4 flex flex-col items-center gap-4 pb-6">
                <div class="flex items-center justify-center gap-2 p-2">
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-not-allowed" 
                            @onclick="() => GoToPage(CurrentPage - 1)" disabled="@(CurrentPage == 1)">
                        <i class="ph ph-caret-left font-bold"></i>
                    </button>
                    
                    <div class="flex items-center gap-1.5 px-2">
                        @{
                            var pageNumbers = GetPageNumbers();
                            foreach (var p in pageNumbers)
                            {
                                if (p == -1)
                                {
                                    <span class="w-10 h-10 flex items-center justify-center text-gray-300">
                                        <i class="ph ph-dots-three-outline text-lg"></i>
                                    </span>
                                }
                                else
                                {
                                    var pageNum = p;
                                    <button class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all
                                                   @(CurrentPage == pageNum ? "bg-gray-900 text-white shadow-lg shadow-gray-200" : "bg-white border border-gray-100 text-gray-400 hover:border-gray-300")"
                                            @onclick="() => GoToPage(pageNum)">
                                        @pageNum
                                    </button>
                                }
                            }
                        }
                    </div>

                    <button class="w-10 h-10 flex items-center justify-center rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-not-allowed" 
                            @onclick="() => GoToPage(CurrentPage + 1)" disabled="@(CurrentPage == TotalPages)">
                        <i class="ph ph-caret-right font-bold"></i>
                    </button>
                </div>
                <div class="text-[11px] font-bold text-gray-400 uppercase tracking-widest">
                    Trang <span class="text-gray-900">@CurrentPage</span> / @TotalPages — Tổng <span class="text-gray-900">@FilteredDanhMuc.Count()</span> danh mục
                </div>
            </div>
        }
    }
</div>

@code {
    private string activeTab = "loaidanhmuc"; // "loaidanhmuc" or "danhmuc"
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;
    private int TotalPages => (int)Math.Ceiling((double)FilteredDanhMuc.Count() / PageSize);

    private List<LoaiDanhMucDto> itemsLoaiDanhMuc = new();
    private List<DanhMucDto> itemsDanhMuc = new();

    private bool showEditorLoai = false;
    private bool showEditorDanh = false;
    private bool isSaving = false;
    
    private LoaiDanhMucCreateUpdateRequest editorLoai = new();
    private DanhMucCreateUpdateRequest editorDanh = new();
    
    private Guid editingId = Guid.Empty;
    private string errorMessage = string.Empty;

    // Filter properties
    private string _searchDanh = "";
    private string searchDanh
    {
        get => _searchDanh;
        set { if (_searchDanh != value) { _searchDanh = value; CurrentPage = 1; } }
    }

    private Guid _filterMaLDM = Guid.Empty;
    private Guid filterMaLDM
    {
        get => _filterMaLDM;
        set { if (_filterMaLDM != value) { _filterMaLDM = value; CurrentPage = 1; } }
    }

    private IEnumerable<DanhMucDto> FilteredDanhMuc
    {
        get
        {
            var query = itemsDanhMuc.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchDanh))
            {
                query = query.Where(x => x.TenDM.Contains(searchDanh, StringComparison.OrdinalIgnoreCase) || 
                                         x.Slug.Contains(searchDanh, StringComparison.OrdinalIgnoreCase));
            }
            if (filterMaLDM != Guid.Empty)
            {
                query = query.Where(x => x.MaLDM == filterMaLDM);
            }
            return query;
        }
    }

    private IEnumerable<DanhMucDto> PaginatedDanhMuc => FilteredDanhMuc.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        int total = TotalPages;
        int current = CurrentPage;

        if (total <= 7)
        {
            for (int i = 1; i <= total; i++) pages.Add(i);
        }
        else
        {
            pages.Add(1);
            int start = Math.Max(2, current - 2);
            int end = Math.Min(total - 1, current + 2);

            if (current <= 4) end = 5;
            if (current >= total - 3) start = total - 4;

            if (start > 2) pages.Add(-1);
            for (int i = start; i <= end; i++) pages.Add(i);
            if (end < total - 1) pages.Add(-1);
            pages.Add(total);
        }
        return pages;
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        itemsLoaiDanhMuc = (await categoryService.GetAllLoaiDanhMucAsync()).ToList();
        itemsDanhMuc = (await categoryService.GetAllAsync()).ToList();
        try {
            allProducts = (await productService.GetAllAsync()).ToList();
        } catch { /* Ignore if products fail to load */ }
    }

    private List<SanPhamDto> allProducts = new();
    private int GetProductCount(Guid maDM) => allProducts.Count(p => p.MaDM == maDM);

    private void NewLoai()
    {
        errorMessage = string.Empty;
        editingId = Guid.Empty;
        editorLoai = new LoaiDanhMucCreateUpdateRequest();
        showEditorLoai = true;
    }

    private void EditLoai(LoaiDanhMucDto ldm)
    {
        errorMessage = string.Empty;
        editingId = ldm.MaLDM;
        editorLoai = new LoaiDanhMucCreateUpdateRequest { TenLDM = ldm.TenLDM };
        showEditorLoai = true;
    }

    private void NewDanh()
    {
        errorMessage = string.Empty;
        editingId = Guid.Empty;
        editorDanh = new DanhMucCreateUpdateRequest();
        if (itemsLoaiDanhMuc != null && itemsLoaiDanhMuc.Any())
        {
            editorDanh.MaLDM = itemsLoaiDanhMuc.First().MaLDM;
        }
        showEditorDanh = true;
    }

    private void EditDanh(DanhMucDto dm)
    {
        errorMessage = string.Empty;
        editingId = dm.MaDM;
        editorDanh = new DanhMucCreateUpdateRequest { MaLDM = dm.MaLDM, TenDM = dm.TenDM };
        showEditorDanh = true;
    }

    private async Task SaveLoai()
    {
        errorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(editorLoai.TenLDM))
        {
            await Swal.FireAsync("Cảnh báo", "Vui lòng nhập tên loại danh mục.", SweetAlertIcon.Warning);
            return;
        }

        if (itemsLoaiDanhMuc.Any(x => x.TenLDM.Equals(editorLoai.TenLDM, StringComparison.OrdinalIgnoreCase) && x.MaLDM != editingId))
        {
            await Swal.FireAsync("Cảnh báo", "Tên loại danh mục này đã tồn tại.", SweetAlertIcon.Warning);
            return;
        }

        isSaving = true;
        try 
        {
            if (editingId == Guid.Empty)
            {
                await categoryService.CreateLoaiDanhMucAsync(editorLoai);
                await Swal.FireAsync(new SweetAlertOptions { Title = "Thành công", Text = "Đã tạo loại danh mục mới", Icon = SweetAlertIcon.Success, Timer = 2000, ShowConfirmButton = false });
            }
            else
            {
                await categoryService.UpdateLoaiDanhMucAsync(editingId, editorLoai);
                await Swal.FireAsync(new SweetAlertOptions { Title = "Thành công", Text = "Đã cập nhật loại danh mục", Icon = SweetAlertIcon.Success, Timer = 2000, ShowConfirmButton = false });
            }

            showEditorLoai = false;
            await Load();
        }
        catch (Exception ex)
        {
            await Swal.FireAsync("Lỗi", ex.Message, SweetAlertIcon.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveDanh()
    {
        errorMessage = string.Empty;
        if (editorDanh.MaLDM == Guid.Empty)
        {
            errorMessage = "Vui lòng chọn loại danh mục gốc.";
            return;
        }
        if (string.IsNullOrWhiteSpace(editorDanh.TenDM))
        {
            errorMessage = "Vui lòng nhập tên danh mục.";
            return;
        }

        if (itemsDanhMuc.Any(x => x.TenDM.Equals(editorDanh.TenDM, StringComparison.OrdinalIgnoreCase) && x.MaLDM == editorDanh.MaLDM && x.MaDM != editingId))
        {
            errorMessage = "Danh mục này đã tồn tại trong danh mục gốc đã chọn.";
            return;
        }

        isSaving = true;
        try
        {
            if (editingId == Guid.Empty)
            {
                await categoryService.CreateAsync(editorDanh);
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Thành công",
                    Text = "Đã tạo danh mục mới",
                    Icon = SweetAlertIcon.Success,
                    Timer = 2000,
                    ShowConfirmButton = false
                });
            }
            else
            {
                await categoryService.UpdateAsync(editingId, editorDanh);
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Thành công",
                    Text = "Đã cập nhật danh mục",
                    Icon = SweetAlertIcon.Success,
                    Timer = 2000,
                    ShowConfirmButton = false
                });
            }
            showEditorDanh = false;
            await Load();
        }
        catch (Exception ex)
        {
            await Swal.FireAsync("Lỗi", ex.Message, SweetAlertIcon.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteLoai(Guid id)
    {
        var confirm = await Swal.FireAsync(new SweetAlertOptions { Title = "Xác nhận xóa?", Icon = SweetAlertIcon.Warning, ShowCancelButton = true });
        if (confirm.IsConfirmed) {
            await categoryService.DeleteLoaiDanhMucAsync(id);
            await Load();
        }
    }
    
    private async Task DeleteDanh(Guid id)
    {
        var confirm = await Swal.FireAsync(new SweetAlertOptions { Title = "Xác nhận xóa?", Icon = SweetAlertIcon.Warning, ShowCancelButton = true });
        if (confirm.IsConfirmed) {
            await categoryService.DeleteAsync(id);
            await Load();
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages) CurrentPage = page;
    }

    private void Cancel() 
    {
        showEditorLoai = false;
        showEditorDanh = false;
    }
}

@if (showEditorLoai)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-[2px] flex items-center justify-center z-50 transition-all">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <h3 class="text-lg font-bold text-gray-800">
                    @(editingId == Guid.Empty ? "Thêm mới" : "Chỉnh sửa") Loại danh mục
                </h3>
                <button class="text-gray-400 hover:text-red-500 transition-colors rounded-lg p-1 hover:bg-red-50" @onclick="Cancel">
                    <i class="ph ph-x text-xl"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg border border-red-200 flex items-center text-sm shadow-sm animate-in fade-in zoom-in duration-200">
                        <i class="ph ph-warning-circle text-lg mr-2 font-bold"></i>
                        @errorMessage
                    </div>
                }
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên loại danh mục <span class="text-red-500">*</span></label>
                    <input type="text" @bind="editorLoai.TenLDM" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Nhập tên..." autofocus />
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <button class="px-5 py-2.5 text-gray-600 hover:bg-gray-200 font-medium rounded-lg transition-colors" @onclick="Cancel" disabled="@isSaving">Hủy</button>
                <button class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors shadow-sm flex items-center" @onclick="SaveLoai" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <i class="ph ph-circle-notch animate-spin mr-2"></i> <span>Đang lưu...</span>
                    }
                    else
                    {
                        <i class="ph ph-floppy-disk mr-2 text-lg"></i> <span>Lưu lại</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@if (showEditorDanh)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-[2px] flex items-center justify-center z-50 transition-all">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <h3 class="text-lg font-bold text-gray-800">
                    @(editingId == Guid.Empty ? "Thêm mới" : "Chỉnh sửa") Danh mục
                </h3>
                <button class="text-gray-400 hover:text-red-500 transition-colors rounded-lg p-1 hover:bg-red-50" @onclick="Cancel">
                    <i class="ph ph-x text-xl"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 bg-red-50 text-red-600 rounded-lg border border-red-200 flex items-center text-sm shadow-sm animate-in fade-in zoom-in duration-200">
                        <i class="ph ph-warning-circle text-lg mr-2 font-bold"></i>
                        @errorMessage
                    </div>
                }
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Thuộc loại danh mục <span class="text-red-500">*</span></label>
                    <select @bind="editorDanh.MaLDM" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                        <option value="@Guid.Empty">-- Chọn loại danh mục --</option>
                        @if (itemsLoaiDanhMuc != null)
                        {
                            @foreach(var ldm in itemsLoaiDanhMuc)
                            {
                                <option value="@ldm.MaLDM">@ldm.TenLDM</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên danh mục <span class="text-red-500">*</span></label>
                    <input type="text" @bind="editorDanh.TenDM" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Nhập tên..." />
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <button class="px-5 py-2.5 text-gray-600 hover:bg-gray-200 font-medium rounded-lg transition-colors" @onclick="Cancel" disabled="@isSaving">Hủy</button>
                <button class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors shadow-sm flex items-center" @onclick="SaveDanh" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <i class="ph ph-circle-notch animate-spin mr-2"></i> <span>Đang lưu...</span>
                    }
                    else
                    {
                        <i class="ph ph-floppy-disk mr-2 text-lg"></i> <span>Lưu lại</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
