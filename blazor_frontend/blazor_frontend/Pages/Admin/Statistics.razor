@page "/admin/dashboard"
@using ApexCharts
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IOrderService OrderService
@inject blazor_frontend.Services.IProductService ProductService
@inject blazor_frontend.Services.IUserService UserService
<PageTitle>Thống kê</PageTitle>

<div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Thống kê Tổng quan</h2>

    @if (isLoading)
    {
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-8 text-center text-gray-500">Đang tải dữ liệu dashboard...</div>
    }
    else
    {

    <!-- Các thẻ thống kê (Cards) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Khối 1 -->
        <div class="bg-blue-50 border border-blue-100 rounded-xl 
                    p-4 flex items-center shadow-sm">
            <div class="p-3 rounded-full bg-blue-100 text-blue-600 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Tổng doanh thu</p>
                <p class="text-lg font-bold text-gray-700">@totalRevenue.ToString("N0") đ</p>
            </div>
        </div>

        <!-- Khối 2 -->
        <div class="bg-green-50 border border-green-100 rounded-xl 
                    p-4 flex items-center shadow-sm">
            <div class="p-3 rounded-full bg-green-100 text-green-600 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Sản phẩm bán ra</p>
                <p class="text-lg font-bold text-gray-700">@totalSoldProducts.ToString("N0")</p>
            </div>
        </div>

        <!-- Khối 3 -->
        <div class="bg-yellow-50 border border-yellow-100 rounded-xl 
                    p-4 flex items-center shadow-sm">
            <div class="p-3 rounded-full bg-yellow-100 text-yellow-600 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Người dùng mới</p>
                <p class="text-lg font-bold text-gray-700">@totalUsers.ToString("N0")</p>
            </div>
        </div>

        <!-- Khối 4 -->
        <div class="bg-red-50 border border-red-100 rounded-xl 
                    p-4 flex items-center shadow-sm">
            <div class="p-3 rounded-full bg-red-100 text-red-600 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Tỷ lệ chốt đơn</p>
                <p class="text-lg font-bold text-gray-700">@conversionRate.ToString("N0")%</p>
            </div>
        </div>
    </div>

    <!-- Khu vực 2 Biểu đồ (Charts) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Biểu đồ 1: Doanh thu -->
        <div class="border border-gray-200 rounded-xl p-6 shadow-sm bg-white">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-gray-800">Doanh thu tuần này</h3>
                <i class="ph ph-dots-three-outline font-bold text-gray-400 cursor-pointer hover:text-blue-500"></i>
            </div>

            <ApexChart TItem="ChartData" Title="" Height="300">
                <ApexPointSeries TItem="ChartData"
                                 Items="revenueData"
                                 Name="Triệu VNĐ"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(e => e.Category)"
                                 YAggregate="@(e => e.Sum(x => x.Value))" />
            </ApexChart>
        </div>

        <!-- Biểu đồ 2: Sản phẩm bán ra -->
        <div class="border border-gray-200 rounded-xl p-6 shadow-sm bg-white">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-gray-800">Sản phẩm bán ra</h3>
                <i class="ph ph-dots-three-outline font-bold text-gray-400 cursor-pointer hover:text-green-500"></i>
            </div>

            <ApexChart TItem="ChartData" Title="" Height="300">
                <ApexPointSeries TItem="ChartData"
                                 Items="productData"
                                 Name="Sản phẩm"
                                 SeriesType="SeriesType.Area"
                                 XValue="@(e => e.Category)"
                                 YAggregate="@(e => e.Sum(x => x.Value))" />
            </ApexChart>
        </div>

    </div>
    }
</div>

@code {
    public class ChartData
    {
        public string Category { get; set; } = string.Empty;
        public int Value { get; set; }
    }

    private bool isLoading = true;
    private decimal totalRevenue;
    private int totalSoldProducts;
    private int totalUsers;
    private decimal conversionRate;

    private List<ChartData> revenueData = new();
    private List<ChartData> productData = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pagedOrders = await OrderService.GetAllPagedAsync(1, 5000);
            var orders = (pagedOrders?.Items ?? Enumerable.Empty<DonHangDto>()).ToList();
            var completedOrders = orders
                .Where(o => NormalizeStatus(o.TrangThaiDH) == "completed")
                .ToList();

            var products = (await ProductService.GetAllAsync()).ToList();
            var users = await UserService.GetAllUsersAsync(1, 1);

            totalRevenue = completedOrders.Sum(x => x.TongTien);
            totalSoldProducts = orders.Sum(x => x.ChiTietDonHangs?.Sum(i => i.SoLuong) ?? 0);
            totalUsers = users?.Total ?? 0;

            var completedCount = orders.Count(o => NormalizeStatus(o.TrangThaiDH) == "completed");
            conversionRate = orders.Count == 0 ? 0 : (decimal)completedCount * 100m / orders.Count;

            var last7Days = Enumerable.Range(0, 7)
                .Select(offset => DateTime.Today.AddDays(-6 + offset))
                .ToList();

            revenueData = last7Days
                .Select(day => new ChartData
                {
                    Category = DayLabel(day),
                    Value = (int)Math.Round(completedOrders
                        .Where(o => o.NgayDat.Date == day.Date)
                        .Sum(o => o.TongTien) / 1_000_000m)
                })
                .ToList();

            productData = last7Days
                .Select(day => new ChartData
                {
                    Category = DayLabel(day),
                    Value = orders
                        .Where(o => o.NgayDat.Date == day.Date)
                        .Sum(o => o.ChiTietDonHangs?.Sum(i => i.SoLuong) ?? 0)
                })
                .ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string DayLabel(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "T2",
            DayOfWeek.Tuesday => "T3",
            DayOfWeek.Wednesday => "T4",
            DayOfWeek.Thursday => "T5",
            DayOfWeek.Friday => "T6",
            DayOfWeek.Saturday => "T7",
            DayOfWeek.Sunday => "CN",
            _ => date.ToString("dd/MM")
        };
    }

    private static string NormalizeStatus(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "choxacnhan" => "pending",
            "dangxuly" => "processing",
            "danggiao" => "shipping",
            "hoantat" => "completed",
            "dahuy" => "cancelled",
            "pending" => "pending",
            "processing" => "processing",
            "shipping" => "shipping",
            "completed" => "completed",
            "cancelled" => "cancelled",
            _ => "pending"
        };
    }
}
