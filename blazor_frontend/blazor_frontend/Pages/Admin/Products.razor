    private async Task HandleMainFileSelected(InputFileChangeEventArgs e)
    {
        Console.WriteLine("HandleMainFileSelected triggered");
        var file = e.File;
        if (file == null) 
        {
            Console.WriteLine("No file selected");
            return;
        }

        try
        {
            Console.WriteLine($"Selected file: {file.Name}, Size: {file.Size}");
            message = "Đang tải ảnh sản phẩm...";
            isError = false;
            StateHasChanged();

            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            var url = await productService.UploadPhotoAsync(stream, file.Name);
            
            if (!string.IsNullOrEmpty(url))
            {
                Console.WriteLine($"Upload success: {url}");
                tempProductImage = url;
                message = "Tải ảnh sản phẩm thành công!";
            }
            else
            {
                Console.WriteLine("Upload failed: No URL returned");
                message = "Tải ảnh thất bại.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Upload exception: {ex.Message}");
            message = $"Lỗi: {ex.Message}";
            isError = true;
        }
        finally
        {
            StateHasChanged();
        }
    }
