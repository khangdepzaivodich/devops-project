@page "/admin/products"
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IProductService productService
@inject blazor_frontend.Services.ICategoryService categoryService
@inject blazor_frontend.Services.IOrderService orderService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject blazor_frontend.Services.AuthState AuthState
@inject SweetAlertService Swal

<PageTitle>Quản lý Sản phẩm</PageTitle>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #e5e7eb;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #d1d5db;
    }
</style>

<div class="bg-white rounded-xl shadow-sm w-full p-6 pb-12 min-h-[600px] flex flex-col">
    @if (!isAuthorized)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-700">Bạn không có quyền truy cập trang này.</div>
    }
    else
    {
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between mb-8">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Quản lý Sản phẩm</h2>
                <p class="text-sm text-gray-500 mt-1">Danh sách sản phẩm trong hệ thống Catalog.</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <div class="relative group">
                    <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500"></i>
                    <input class="rounded-xl border border-gray-200 pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all w-64 shadow-sm"
                           placeholder="Tìm tên sản phẩm..."
                           @bind="searchText" @bind:event="oninput" />
                </div>
                <div class="relative w-48">
                    <i class="ph ph-folders absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <select @bind="filterMaLDM" class="w-full pl-10 pr-10 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 bg-white cursor-pointer shadow-sm text-sm text-gray-600 font-medium appearance-none">
                        <option value="@Guid.Empty">Tất cả loại</option>
                        @if (loaiDanhMucs != null)
                        {
                            @foreach (var ldm in loaiDanhMucs)
                            {
                                <option value="@ldm.MaLDM">@ldm.TenLDM</option>
                            }
                        }
                    </select>
                    <i class="ph ph-caret-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
                <div class="relative w-48">
                    <i class="ph ph-filter absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <select @bind="filterMaDM" class="w-full pl-10 pr-10 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 bg-white cursor-pointer shadow-sm text-sm text-gray-600 font-medium appearance-none">
                        <option value="@Guid.Empty">Tất cả danh mục</option>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories.Where(c => filterMaLDM == Guid.Empty || c.MaLDM == filterMaLDM))
                            {
                                <option value="@cat.MaDM">@cat.TenDM</option>
                            }
                        }
                    </select>
                    <i class="ph ph-caret-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>

                <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl transition-all flex items-center gap-2 shadow-sm hover:shadow-blue-200 active:scale-95" @onclick="New">
                    <i class="ph ph-plus-circle text-xl"></i>
                    Thêm sản phẩm
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="mb-6 rounded-xl border @(isError ? "border-red-200 bg-red-50 text-red-700" : "border-green-200 bg-green-50 text-green-700") px-4 py-3 text-sm flex items-center gap-2">
                <i class="ph @(isError ? "ph-warning-circle" : "ph-check-circle") text-lg"></i>
                @message
            </div>
        }

        <div class="flex-1 overflow-x-auto border border-gray-100 rounded-xl shadow-sm custom-scrollbar">
            <table class="min-w-full text-left border-collapse bg-white table-auto">
                    <thead>
                        <tr class="bg-gray-50/50 text-gray-500 text-[11px] uppercase tracking-widest font-bold whitespace-nowrap">
                            <th class="p-4 border-b border-gray-100">Sản phẩm</th>
                            <th class="p-4 border-b border-gray-100">Phân loại</th>
                            <th class="p-4 border-b border-gray-100">Mô tả</th>
                            <th class="p-4 border-b border-gray-100 text-center">Biến thể</th>
                            <th class="p-4 border-b border-gray-100 text-center">Kho</th>
                            <th class="p-4 border-b border-gray-100 text-center">Lượt bán</th>
                            <th class="p-4 border-b border-gray-100 text-center">Ngày tạo</th>
                            <th class="p-4 border-b border-gray-100 text-right">Thao tác</th>
                            <th class="p-4 border-b border-gray-100 text-right">Ảnh</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 text-sm">
                        @if (isLoading)
                        {
                            <tr><td colspan="8" class="p-4 text-center py-20">
                                <div class="inline-block h-10 w-10 animate-spin rounded-full border-4 border-solid border-blue-600 border-r-transparent align-[-0.125em]"></div>
                                <p class="mt-4 text-gray-500 font-medium">Đang tải dữ liệu...</p>
                            </td></tr>
                        }
                        else if (!PaginatedItems.Any())
                        {
                            <tr><td colspan="8" class="p-4 text-center py-20 text-gray-400 italic">Không có sản phẩm nào được tìm thấy</td></tr>
                        }
                        else
                        {
                            @foreach (var sp in PaginatedItems)
                            {
                                var catName = GetCategoryName(sp.MaDM);
                                var previewImage = sp.ChiTietSanPhams?.FirstOrDefault()?.Anh ?? "product1.jpg";
                                var totalStock = sp.ChiTietSanPhams?.Sum(x => x.SoLuong) ?? 0;
                                <tr class="border-b border-gray-50 hover:bg-gray-50/80 transition-colors">
                                    <td class="p-4 align-top">
                                        <p class="font-bold text-gray-900 leading-tight">@sp.TenSP</p>
                                    </td>

                                    <td class="p-4 align-top whitespace-nowrap">
                                        <div class="flex flex-col gap-1.5">
                                            <span class="inline-flex items-center w-fit px-2 py-0.5 rounded-md text-[10px] font-bold bg-blue-50 text-blue-700 uppercase tracking-wider">@catName</span>
                                            <span class="text-xs text-gray-400">@GetLoaiDanhMucName(sp.MaDM)</span>
                                        </div>
                                    </td>

                                    <td class="p-4 align-top">
                                        <div class="text-xs text-gray-500 line-clamp-2 max-w-xs">@(!string.IsNullOrWhiteSpace(sp.MoTa) ? sp.MoTa : "Chưa có mô tả")</div>
                                    </td>

                                    <td class="p-4 text-center align-top">
                                        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-bold bg-emerald-50 text-emerald-700">@((sp.ChiTietSanPhams?.Count ?? 0))</span>
                                    </td>

                                    <td class="p-4 text-center align-top">
                                        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-bold bg-amber-50 text-amber-700">@totalStock</span>
                                    </td>

                                    <td class="p-4 text-center align-top">
                                        <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-bold bg-purple-50 text-purple-700">@sp.LuotBan</span>
                                    </td>

                                    <td class="p-4 text-center align-top whitespace-nowrap">
                                        <span class="text-[10px] font-medium text-gray-400 block">@sp.NgayTao.ToString("dd/MM/yyyy")</span>
                                        <span class="text-[9px] text-gray-300">@sp.NgayTao.ToString("HH:mm")</span>
                                    </td>

                                    <td class="p-4 text-right space-x-1 align-top whitespace-nowrap">
                                        <button class="p-2 rounded-lg text-emerald-600 hover:bg-emerald-50 transition-colors" title="Biến thể" @onclick="() => OpenVariantManager(sp)">
                                            <i class="ph ph-tshirt text-xl"></i>
                                        </button>
                                        <button class="p-2 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors" title="Sửa" @onclick="() => Edit(sp)">
                                            <i class="ph ph-pencil-simple text-xl"></i>
                                        </button>
                                        <button class="p-2 rounded-lg text-red-600 hover:bg-red-50 transition-colors" title="Xóa" @onclick="() => Delete(sp.MaSP)">
                                            <i class="ph ph-trash text-xl"></i>
                                        </button>
                                    </td>

                                    <td class="p-4 text-right align-top">
                                        <img src="@previewImage" alt="@sp.TenSP" class="inline-block h-12 w-12 rounded-lg object-cover border border-gray-100 shadow-sm" onerror="this.src='product1.jpg';" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
        </div>

        <!-- Phân trang UI (Căn giữa theo style storefront) -->
        @if (!isLoading && TotalPages > 1)
        {
            <div class="mt-8 mb-4 flex flex-col items-center gap-4 pb-6">
                <div class="flex items-center justify-center gap-2 p-2">
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-not-allowed" 
                            @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">
                        <i class="ph ph-caret-left"></i>
                    </button>
                    
                    <div class="flex items-center gap-1.5 px-2">
                        @{
                            var pageNumbers = GetPageNumbers();
                            foreach (var p in pageNumbers)
                            {
                                if (p == -1)
                                {
                                    <span class="w-10 h-10 flex items-center justify-center text-gray-400">
                                        <i class="ph ph-dots-three-outline text-lg"></i>
                                    </span>
                                }
                                else
                                {
                                    var pageNum = p;
                                    <button class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all
                                                   @(currentPage == pageNum ? "bg-gray-900 text-white shadow-lg shadow-gray-200" : "bg-white border border-gray-100 text-gray-500 hover:border-gray-300")"
                                            @onclick="() => ChangePage(pageNum)">
                                        @pageNum
                                    </button>
                                }
                            }
                        }
                    </div>

                    <button class="w-10 h-10 flex items-center justify-center rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-not-allowed" 
                            @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == TotalPages)">
                        <i class="ph ph-caret-right"></i>
                    </button>
                </div>
                <div class="text-[11px] font-bold text-gray-400 uppercase tracking-widest">
                    Trang <span class="text-gray-900">@currentPage</span> / @TotalPages — Tổng <span class="text-gray-900">@FilteredItems.Count()</span> sản phẩm
                </div>
            </div>
        }
    }
</div>

@if (showEditor)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 backdrop-blur-sm px-4" @onclick="CloseEditor">
        <div class="w-full max-w-5xl rounded-3xl bg-white p-8 shadow-2xl transition-all scale-100 animate-in fade-in zoom-in duration-200 flex flex-col max-h-[90vh]" @onclick:stopPropagation="true">
            <div class="mb-8 flex items-center justify-between">
                <div>
                    <h3 class="text-2xl font-bold text-gray-900">@(editingId == Guid.Empty ? "Tạo sản phẩm mới" : "Cập nhật sản phẩm")</h3>
                    <p class="text-sm text-gray-500 mt-1">Hoàn thiện thông tin cơ bản để hiển thị trên cửa hàng.</p>
                </div>
                <button class="rounded-xl p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-900 transition-all" @onclick="CloseEditor">
                    <i class="ph ph-x text-2xl"></i>
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 flex-1 overflow-hidden">
                <!-- Thông tin cơ bản -->
                <div class="lg:col-span-5 space-y-6 overflow-y-auto pr-4 custom-scrollbar">
                    <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest flex items-center gap-2">
                        <i class="ph ph-info text-lg text-blue-500"></i>
                        Thông tin cơ bản
                    </h4>
                    
                    <div class="space-y-5">
                        <div>
                            <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Tên sản phẩm</label>
                            <div class="relative group">
                                <i class="ph ph-tag absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
                                <input class="w-full rounded-2xl border border-gray-200 pl-11 pr-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-gray-50/30" 
                                       placeholder="Ví dụ: Áo thun Polo Classic" @bind="editor.TenSP" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Loại danh mục</label>
                                <div class="relative group">
                                    <i class="ph ph-folders absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
                                    <select class="w-full rounded-2xl border border-gray-200 pl-11 pr-10 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-gray-50/30 appearance-none" @bind="editorMaLDM">
                                        <option value="@Guid.Empty">-- Chọn loại danh mục --</option>
                                        @if (loaiDanhMucs != null)
                                        {
                                            @foreach (var ldm in loaiDanhMucs)
                                            {
                                                <option value="@ldm.MaLDM">@ldm.TenLDM</option>
                                            }
                                        }
                                    </select>
                                    <i class="ph ph-caret-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                                </div>
                            </div>

                            <div>
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Danh mục</label>
                                <div class="relative group">
                                    <i class="ph ph-folder-open absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
                                    <select class="w-full rounded-2xl border border-gray-200 pl-11 pr-10 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-gray-50/30 appearance-none" @bind="editor.MaDM" disabled="@(editorMaLDM == Guid.Empty)">
                                        <option value="@Guid.Empty">-- Chọn danh mục --</option>
                                        @if (categories != null)
                                        {
                                            @foreach (var cat in categories.Where(c => c.MaLDM == editorMaLDM))
                                            {
                                                <option value="@cat.MaDM">@cat.TenDM</option>
                                            }
                                        }
                                    </select>
                                    <i class="ph ph-caret-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Mô tả sản phẩm</label>
                            <div class="relative group">
                                <i class="ph ph-article absolute left-4 top-4 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
                                <textarea class="min-h-[220px] w-full rounded-2xl border border-gray-200 pl-11 pr-4 py-3.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-gray-50/30 resize-none" 
                                          placeholder="Mô tả chi tiết về sản phẩm..." @bind="editor.MoTa"></textarea>
                            </div>
                        </div>

                        @if (editingId != Guid.Empty && editingNgayTao.HasValue)
                        {
                            <div>
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Ngày tạo hệ thống</label>
                                <div class="relative">
                                    <i class="ph ph-calendar-blank absolute left-4 top-1/2 -translate-y-1/2 text-gray-300"></i>
                                    <input class="w-full rounded-2xl border border-gray-100 pl-11 pr-4 py-3.5 text-sm bg-gray-100/50 text-gray-400 cursor-not-allowed" 
                                           value="@editingNgayTao.Value.ToString("dd/MM/yyyy HH:mm")" readonly />
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Quản lý Biến thể -->
                <div class="lg:col-span-7 flex flex-col overflow-hidden">
                    <div class="mb-4 flex items-center justify-between">
                        <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest flex items-center gap-2">
                            <i class="ph ph-palette text-lg text-emerald-500"></i>
                            Biến thể & Hình ảnh
                        </h4>
                        <button class="text-blue-600 hover:text-blue-700 text-xs font-bold flex items-center gap-1.5 px-3 py-1.5 rounded-lg hover:bg-blue-50 transition-all" @onclick="AddNewVariantToEditor">
                            <i class="ph ph-plus-circle text-lg"></i>
                            Thêm biến thể
                        </button>
                    </div>

                    <div class="flex-1 overflow-y-auto space-y-4 pr-2 custom-scrollbar">
                        @if (!editorVariants.Any())
                        {
                            <div class="h-full flex flex-col items-center justify-center text-gray-400 p-12 border-2 border-dashed border-gray-100 rounded-3xl bg-gray-50/30">
                                <i class="ph ph-selection-plus text-5xl mb-4 opacity-20"></i>
                                <p class="text-sm italic font-medium">Chưa có biến thể nào. Hãy thêm ít nhất 1 biến thể.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var v in editorVariants)
                            {
                                <div class="relative group/card bg-white border border-gray-100 rounded-3xl p-5 shadow-sm hover:shadow-md transition-all border-l-4 border-l-emerald-500">
                                    <button class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-white border border-gray-100 shadow-sm text-red-500 hover:bg-red-50 flex items-center justify-center opacity-0 group-hover/card:opacity-100 transition-all z-10" @onclick="() => RemoveVariantFromEditor(v)">
                                        <i class="ph ph-trash"></i>
                                    </button>
                                    
                                    <div class="flex gap-6">
                                        <!-- Chọn ảnh cho biến thể -->
                                        <div class="relative w-28 h-28 shrink-0">
                                            <label class="w-full h-full rounded-2xl border-2 border-dashed border-gray-100 bg-gray-50 flex flex-col items-center justify-center overflow-hidden cursor-pointer hover:border-emerald-400 hover:bg-emerald-50/30 transition-all group/img">
                                                @if (!string.IsNullOrEmpty(v.Anh))
                                                {
                                                    <img src="@v.Anh" class="w-full h-full object-cover" />
                                                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover/img:opacity-100 flex items-center justify-center transition-opacity">
                                                        <i class="ph ph-pencil-simple text-white text-xl"></i>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <i class="ph ph-image-plus text-2xl text-gray-300 group-hover/img:text-emerald-500 transition-colors"></i>
                                                    <span class="text-[10px] text-gray-400 mt-1 font-bold">Thêm ảnh</span>
                                                }
                                                <InputFile OnChange="(e) => HandleVariantFileSelected(e, v)" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" />
                                            </label>
                                        </div>

                                        <!-- Thông tin biến thể -->
                                        <div class="flex-1 grid grid-cols-2 gap-x-4 gap-y-3">
                                            <div>
                                                <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Màu sắc</label>
                                                <input class="w-full rounded-xl border border-gray-100 px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500 bg-gray-50/50" 
                                                       placeholder="Đỏ, Xanh..." @bind="v.Mau" />
                                            </div>
                                            <div>
                                                <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Kích cỡ</label>
                                                <div class="relative">
                                                    <select class="w-full rounded-xl border border-gray-100 px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500 bg-gray-50/50 appearance-none" @bind="v.KichCo">
                                                        <option value="Mặc định">Mặc định</option>
                                                        <option value="Freesize">Freesize</option>
                                                        <option value="XS">XS</option>
                                                        <option value="S">S</option>
                                                        <option value="M">M</option>
                                                        <option value="L">L</option>
                                                        <option value="XL">XL</option>
                                                        <option value="XXL">XXL</option>
                                                        <option value="3XL">3XL</option>
                                                    </select>
                                                    <i class="ph ph-caret-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                                                </div>
                                            </div>
                                            <div>
                                                <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Giá bán (đ)</label>
                                                <input type="number" class="w-full rounded-xl border border-gray-100 px-4 py-2.5 text-sm font-bold text-blue-600 focus:outline-none focus:border-emerald-500 bg-gray-50/50" 
                                                       @bind="v.Gia" />
                                            </div>
                                            <div>
                                                <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Kho</label>
                                                <input type="number" class="w-full rounded-xl border border-gray-100 px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500 bg-gray-50/50" 
                                                       @bind="v.SoLuong" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="mt-10 flex items-center justify-end gap-4">
                <button class="rounded-2xl px-6 py-3 text-sm font-bold text-gray-500 hover:bg-gray-100 transition-all" @onclick="CloseEditor">Hủy bỏ</button>
                <button class="rounded-2xl bg-blue-600 px-8 py-3 text-sm font-bold text-white hover:bg-blue-700 shadow-lg shadow-blue-200 active:scale-95 transition-all flex items-center gap-2" @onclick="SaveProduct">
                    <i class="ph ph-check-circle text-lg"></i>
                    @(editingId == Guid.Empty ? "Tạo sản phẩm" : "Lưu thay đổi")
                </button>
            </div>
        </div>
    </div>
}

@if (showVariantManager)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 backdrop-blur-sm px-4" @onclick="CloseVariantManager">
        <div class="w-full max-w-6xl rounded-3xl bg-white p-8 shadow-2xl max-h-[90vh] flex flex-col transition-all animate-in fade-in zoom-in duration-200" @onclick:stopPropagation="true">
            <div class="mb-8 flex items-center justify-between">
                <div>
                    <h3 class="text-2xl font-bold text-gray-900">Quản lý biến thể</h3>
                    <p class="text-sm text-gray-500 mt-1">Sản phẩm: <span class="font-bold text-blue-600">@selectedProductName</span></p>
                </div>
                <button class="rounded-xl p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-900 transition-all" @onclick="CloseVariantManager">
                    <i class="ph ph-x text-2xl"></i>
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 flex-1 overflow-hidden">
                <!-- Danh sách biến thể -->
                <div class="lg:col-span-7 flex flex-col overflow-hidden">
                    <div class="mb-4 flex items-center justify-between">
                        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Danh sách hiện tại</h4>
                        <button class="text-blue-600 hover:text-blue-700 text-sm font-bold flex items-center gap-1.5" @onclick="NewVariant">
                            <i class="ph ph-plus-circle text-lg"></i>
                            Thêm mới
                        </button>
                    </div>
                    
                    <div class="flex-1 overflow-y-auto rounded-2xl border border-gray-100 shadow-sm bg-gray-50/30">
                        <table class="w-full text-left text-sm border-collapse">
                            <thead class="sticky top-0 bg-white shadow-sm z-10">
                                <tr class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                                    <th class="p-4">Ảnh</th>
                                    <th class="p-4">Màu sắc</th>
                                    <th class="p-4 text-center">Size</th>
                                    <th class="p-4 text-right">Giá bán</th>
                                    <th class="p-4 text-center">Kho</th>
                                    <th class="p-4 text-right"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                                @if (variantsLoading)
                                {
                                    <tr><td colspan="6" class="p-12 text-center">
                                        <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-solid border-blue-600 border-r-transparent"></div>
                                    </td></tr>
                                }
                                else if (!variants.Any())
                                {
                                    <tr><td colspan="6" class="p-12 text-center text-gray-400 italic">Chưa có biến thể nào được tạo</td></tr>
                                }
                                else
                                {
                                    @foreach (var v in variants)
                                    {
                                        <tr class="hover:bg-white transition-colors group">
                                            <td class="p-3">
                                                <img src="@v.Anh" class="h-10 w-10 rounded-lg object-cover border border-gray-100 shadow-sm" onerror="this.src='product1.jpg';" />
                                            </td>
                                            <td class="p-4 font-bold text-gray-900">@v.Mau</td>
                                            <td class="p-4 text-center">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold bg-gray-100 text-gray-600">@v.KichCo</span>
                                            </td>
                                            <td class="p-4 text-right font-bold text-blue-600">@v.Gia.ToString("N0")đ</td>
                                            <td class="p-4 text-center font-medium text-gray-500">@v.SoLuong</td>
                                            <td class="p-4 text-right whitespace-nowrap">
                                                <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                                    <button class="p-2 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors" @onclick="() => EditVariant(v)">
                                                        <i class="ph ph-pencil-simple text-lg"></i>
                                                    </button>
                                                    <button class="p-2 rounded-lg text-red-600 hover:bg-red-50 transition-colors" @onclick="() => DeleteVariant(v.MaCTSP)">
                                                        <i class="ph ph-trash text-lg"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Form chỉnh sửa/thêm -->
                <div class="lg:col-span-5 flex flex-col">
                    <div class="rounded-3xl border border-gray-100 bg-gray-50/50 p-6 shadow-inner">
                        <h4 class="mb-6 text-sm font-bold text-gray-900 flex items-center gap-2">
                            <i class="ph ph-sparkle text-blue-500 text-lg"></i>
                            @(variantEditingId == Guid.Empty ? "Thêm biến thể mới" : "Cập nhật biến thể")
                        </h4>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div class="col-span-1">
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Màu sắc</label>
                                <input class="w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-white" 
                                       placeholder="Đỏ, Xanh..." @bind="variantEditor.Mau" />
                            </div>
                            <div class="col-span-1">
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Kích cỡ (Size)</label>
                                <div class="relative">
                                    <select class="w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-white appearance-none" @bind="variantEditor.KichCo">
                                        <option value="Mặc định">Mặc định</option>
                                        <option value="Freesize">Freesize</option>
                                        <option value="XS">XS</option>
                                        <option value="S">S</option>
                                        <option value="M">M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                        <option value="3XL">3XL</option>
                                    </select>
                                    <i class="ph ph-caret-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                                </div>
                            </div>
                            <div class="col-span-1">
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Giá bán</label>
                                <div class="relative">
                                    <input type="number" class="w-full rounded-xl border border-gray-200 pl-4 pr-10 py-2.5 text-sm font-bold text-blue-600 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-white" 
                                           @bind="variantEditor.Gia" />
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs font-bold">đ</span>
                                </div>
                            </div>
                            <div class="col-span-1">
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Số lượng kho</label>
                                <input type="number" class="w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-white" 
                                       @bind="variantEditor.SoLuong" />
                            </div>
                            
                            <div class="col-span-2 mt-2">
                                <label class="mb-2 block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hình ảnh minh họa</label>
                                <div class="flex items-start gap-4">
                                    <div class="relative w-24 h-24 shrink-0 group">
                                        <div class="w-full h-full rounded-2xl border-2 border-dashed border-gray-200 bg-white flex flex-col items-center justify-center overflow-hidden transition-all group-hover:border-blue-400">
                                            @if (!string.IsNullOrEmpty(variantEditor.Anh))
                                            {
                                                <img src="@variantEditor.Anh" class="w-full h-full object-cover" />
                                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity" @onclick='() => variantEditor.Anh = ""'>
                                                    <i class="ph ph-trash text-white text-xl"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <i class="ph ph-image text-2xl text-gray-300"></i>
                                                <span class="text-[10px] text-gray-400 mt-1">Trống</span>
                                            }
                                        </div>
                                    </div>
                                    
                                    <div class="flex-1 space-y-3">
                                        <div class="relative">
                                            <input class="w-full rounded-xl border border-gray-200 px-4 py-2.5 text-xs focus:outline-none focus:border-blue-500 transition-all bg-white" 
                                                   placeholder="Dán URL ảnh hoặc tải lên..." @bind="variantEditor.Anh" />
                                        </div>
                                        <div class="relative w-full">
                                            <label class="w-full bg-white hover:bg-gray-100 text-gray-700 px-4 py-2.5 rounded-xl border border-gray-200 flex items-center justify-center gap-2 text-xs font-bold transition-all shadow-sm cursor-pointer">
                                                <i class="ph ph-upload-simple text-lg text-blue-500"></i>
                                                <span>Chọn ảnh từ máy tính</span>
                                                <InputFile OnChange="HandleFileSelected" class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*" />
                                            </label>
                                        </div>
                                        <p class="text-[10px] text-gray-400 px-1 italic">* Khuyên dùng ảnh vuông, tối đa 5MB.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-8 flex items-center gap-3">
                            <button class="flex-1 rounded-xl border border-gray-200 px-4 py-3 text-sm font-bold text-gray-500 hover:bg-white transition-all shadow-sm" @onclick="CancelVariantEdit">Làm lại</button>
                            <button class="flex-2 rounded-xl bg-gray-900 px-4 py-3 text-sm font-bold text-white hover:bg-black shadow-lg shadow-gray-200 active:scale-95 transition-all flex items-center justify-center gap-2" @onclick="SaveVariant">
                                <i class="ph ph-floppy-disk text-lg"></i>
                                @(variantEditingId == Guid.Empty ? "Tạo biến thể" : "Cập nhật")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<SanPhamDto> items = new();
    private List<DanhMucDto> categories = new();
    private List<LoaiDanhMucDto> loaiDanhMucs = new();
    private bool showEditor;
    private SanPhamCreateRequest editor = new();
    private List<ChiTietSanPhamCreateRequest> editorVariants = new();
    private Guid editingId = Guid.Empty;
    private DateTime? editingNgayTao;
    private Guid selectedMaLDM = Guid.Empty;
    private string tempProductImage = string.Empty;
    
    private Guid _editorMaLDM = Guid.Empty;
    private Guid editorMaLDM
    {
        get => _editorMaLDM;
        set
        {
            if (_editorMaLDM != value)
            {
                _editorMaLDM = value;
                var firstCat = categories.FirstOrDefault(c => c.MaLDM == value);
                editor.MaDM = firstCat?.MaDM ?? Guid.Empty;
            }
        }
    }
    private bool isAuthorized;
    private int currentPage = 1;
    private int pageSize = 10;

    private int TotalPages => (int)Math.Ceiling((double)FilteredItems.Count() / pageSize);

    private IEnumerable<SanPhamDto> PaginatedItems => FilteredItems
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            currentPage = page;
        }
    }

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        int total = TotalPages;
        int current = currentPage;

        if (total <= 7)
        {
            for (int i = 1; i <= total; i++) pages.Add(i);
        }
        else
        {
            pages.Add(1);

            int start = Math.Max(2, current - 2);
            int end = Math.Min(total - 1, current + 2);

            if (current <= 4) end = 5;
            if (current >= total - 3) start = total - 4;

            if (start > 2) pages.Add(-1);

            for (int i = start; i <= end; i++)
            {
                pages.Add(i);
            }

            if (end < total - 1) pages.Add(-1);

            pages.Add(total);
        }
        return pages;
    }

    private string _searchText = string.Empty;
    private string searchText 
    { 
        get => _searchText; 
        set { if (_searchText != value) { _searchText = value; currentPage = 1; } } 
    }

    private Guid _filterMaDM = Guid.Empty;
    private Guid filterMaDM
    {
        get => _filterMaDM;
        set { if (_filterMaDM != value) { _filterMaDM = value; currentPage = 1; } }
    }

    private string? message;
    private bool isError;

    private bool showVariantManager;
    private bool variantsLoading;
    private Guid selectedProductId;
    private string selectedProductName = string.Empty;
    private List<ChiTietSanPhamDto> variants = new();
    private Guid variantEditingId = Guid.Empty;
    private ChiTietSanPhamCreateRequest variantEditor = new();

    private Guid _filterMaLDM = Guid.Empty;
    private Guid filterMaLDM
    {
        get => _filterMaLDM;
        set 
        { 
            if (_filterMaLDM != value) 
            { 
                _filterMaLDM = value; 
                _filterMaDM = Guid.Empty; // Reset danh mục khi đổi loại
                currentPage = 1; 
            } 
        }
    }

    private IEnumerable<SanPhamDto> FilteredItems
    {
        get
        {
            var query = items.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(x => x.TenSP.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }
            if (filterMaLDM != Guid.Empty)
            {
                var validMaDMs = categories.Where(c => c.MaLDM == filterMaLDM).Select(c => c.MaDM).ToList();
                query = query.Where(x => validMaDMs.Contains(x.MaDM));
            }
            if (filterMaDM != Guid.Empty)
            {
                query = query.Where(x => x.MaDM == filterMaDM);
            }
            return query;
        }
    }

    [Inject] private blazor_frontend.Services.IAuthService AuthService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        
        var isAdmin = string.Equals(AuthState.Role, "ADMIN", StringComparison.OrdinalIgnoreCase);
        var isStaff = string.Equals(AuthState.Role, "STAFF", StringComparison.OrdinalIgnoreCase);
        isAuthorized = isAdmin || isStaff;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/account/signin?returnUrl=/admin/products");
            return;
        }

        await Load();
    }

    private async Task Load()
    {
        isLoading = true;
        try
        {
            loaiDanhMucs = (await categoryService.GetAllLoaiDanhMucAsync()).ToList();
            categories = (await categoryService.GetAllAsync()).ToList();
            items = (await productService.GetAllAsync()).ToList();
            message = null;
        }
        catch (Exception ex)
        {
            message = $"Không tải được dữ liệu: {ex.Message}";
            isError = true;
        }
        finally
        {
            isLoading = false;
        }
    }



    private string GetCategoryName(Guid maDM) => categories.FirstOrDefault(c => c.MaDM == maDM)?.TenDM ?? maDM.ToString();

    private string GetLoaiDanhMucName(Guid maDM) => categories.FirstOrDefault(c => c.MaDM == maDM)?.TenLDM ?? string.Empty;

    private void New()
    {
        editingId = Guid.Empty;
        editingNgayTao = null;
        selectedMaLDM = Guid.Empty;
        tempProductImage = string.Empty;
        editor = new SanPhamCreateRequest();
        editorVariants = new List<ChiTietSanPhamCreateRequest> 
        { 
            new ChiTietSanPhamCreateRequest { Mau = "Mặc định", KichCo = "Mặc định", Gia = 0, SoLuong = 100 } 
        };
        if (loaiDanhMucs != null && loaiDanhMucs.Any())
        {
            editorMaLDM = loaiDanhMucs.First().MaLDM;
        }
        showEditor = true;
    }

    private void AddNewVariantToEditor()
    {
        editorVariants.Add(new ChiTietSanPhamCreateRequest { Mau = "", KichCo = "", Gia = 0, SoLuong = 100 });
    }

    private void RemoveVariantFromEditor(ChiTietSanPhamCreateRequest v)
    {
        editorVariants.Remove(v);
    }

    private async Task Edit(SanPhamDto it)
    {
        editingId = it.MaSP;
        editingNgayTao = it.NgayTao;
        selectedMaLDM = categories.FirstOrDefault(c => c.MaDM == it.MaDM)?.MaLDM ?? Guid.Empty;
        editor = new SanPhamCreateRequest { MaDM = it.MaDM, TenSP = it.TenSP, MoTa = it.MoTa };
        
        var cat = categories.FirstOrDefault(c => c.MaDM == it.MaDM);
        if (cat != null)
        {
            _editorMaLDM = cat.MaLDM; // Use backing field to avoid triggering setter which resets MaDM
        }
        
        // Tải biến thể hiện tại vào editor
        var existing = await productService.GetVariantsAsync(it.MaSP);
        editorVariants = existing.Select(v => new ChiTietSanPhamCreateRequest 
        { 
            MaSP = it.MaSP,
            Mau = v.Mau,
            KichCo = v.KichCo,
            Gia = v.Gia,
            SoLuong = v.SoLuong,
            Anh = v.Anh
        }).ToList();
        
        showEditor = true;
    }

    private void CloseEditor() => showEditor = false;

    private async Task SaveProduct()
    {
        if (editor.MaDM == Guid.Empty || string.IsNullOrWhiteSpace(editor.TenSP))
        {
            await Swal.FireAsync("Cảnh báo", "Vui lòng nhập tên sản phẩm và chọn danh mục.", SweetAlertIcon.Warning);
            return;
        }

        try
        {
            if (editingId == Guid.Empty)
            {
                var res = await productService.CreateAsync(editor);
                if (res != null)
                {
                    // Lưu toàn bộ biến thể
                    foreach (var v in editorVariants)
                    {
                        v.MaSP = res.MaSP;
                        await productService.CreateVariantAsync(v);
                    }
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Thành công",
                        Text = "Đã tạo sản phẩm và các biến thể",
                        Icon = SweetAlertIcon.Success,
                        Timer = 2000,
                        ShowConfirmButton = false
                    });
                }
                else
                {
                    await Swal.FireAsync("Lỗi", "Tạo sản phẩm thất bại.", SweetAlertIcon.Error);
                }
            }
            else
            {
                var ok = await productService.UpdateAsync(editingId, editor);
                if (ok)
                {
                    await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Thành công",
                        Text = "Đã cập nhật thông tin sản phẩm.",
                        Icon = SweetAlertIcon.Success,
                        Timer = 2000,
                        ShowConfirmButton = false
                    });
                }
                else
                {
                    await Swal.FireAsync("Lỗi", "Cập nhật sản phẩm thất bại.", SweetAlertIcon.Error);
                }
            }

            showEditor = false;
            await Load();
        }
        catch (Exception ex)
        {
            await Swal.FireAsync("Lỗi hệ thống", ex.Message, SweetAlertIcon.Error);
        }
    }

    private async Task Delete(Guid id)
    {
        var result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Xác nhận xóa?",
            Text = "Dữ liệu sản phẩm sẽ bị xóa vĩnh viễn!",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Xóa ngay",
            CancelButtonText = "Hủy",
            ConfirmButtonColor = "#ef4444"
        });

        if (result.IsConfirmed)
        {
            if (await productService.DeleteAsync(id))
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Đã xóa",
                    Icon = SweetAlertIcon.Success,
                    Timer = 1500,
                    ShowConfirmButton = false
                });
                await Load();
            }
            else
            {
                await Swal.FireAsync("Thất bại", "Không thể xóa sản phẩm này.", SweetAlertIcon.Error);
            }
        }
    }

    private async Task OpenVariantManager(SanPhamDto product)
    {
        selectedProductId = product.MaSP;
        selectedProductName = product.TenSP;
        showVariantManager = true;
        variantEditingId = Guid.Empty;
        variantEditor = new ChiTietSanPhamCreateRequest { MaSP = selectedProductId };
        await LoadVariants();
    }

    private void CloseVariantManager() => showVariantManager = false;

    private async Task LoadVariants()
    {
        variantsLoading = true;
        try
        {
            variants = (await productService.GetVariantsAsync(selectedProductId)).ToList();
        }
        finally
        {
            variantsLoading = false;
        }
    }

    private void NewVariant()
    {
        variantEditingId = Guid.Empty;
        variantEditor = new ChiTietSanPhamCreateRequest { MaSP = selectedProductId };
    }

    private void EditVariant(ChiTietSanPhamDto variant)
    {
        variantEditingId = variant.MaCTSP;
        variantEditor = new ChiTietSanPhamCreateRequest
        {
            MaSP = selectedProductId,
            Mau = variant.Mau,
            KichCo = variant.KichCo,
            Gia = variant.Gia,
            SoLuong = variant.SoLuong,
            Anh = variant.Anh
        };
    }

    private void CancelVariantEdit()
    {
        variantEditingId = Guid.Empty;
        variantEditor = new ChiTietSanPhamCreateRequest { MaSP = selectedProductId };
    }

    private async Task SaveVariant()
    {
        if (selectedProductId == Guid.Empty || string.IsNullOrWhiteSpace(variantEditor.Mau) || string.IsNullOrWhiteSpace(variantEditor.KichCo))
        {
            message = "Vui lòng nhập màu và kích cỡ cho biến thể.";
            isError = true;
            return;
        }

        variantEditor.MaSP = selectedProductId;

        try
        {
            if (variantEditingId == Guid.Empty)
            {
                var created = await productService.CreateVariantAsync(variantEditor);
                if (created != null)
                {
                    message = "Đã tạo biến thể.";
                    isError = false;
                }
                else
                {
                    message = "Tạo biến thể thất bại.";
                    isError = true;
                }
            }
            else
            {
                var ok = await productService.UpdateVariantAsync(variantEditingId, new ChiTietSanPhamUpdateRequest
                {
                    Mau = variantEditor.Mau,
                    KichCo = variantEditor.KichCo,
                    Gia = variantEditor.Gia,
                    SoLuong = variantEditor.SoLuong,
                    Anh = variantEditor.Anh
                });

                if (ok)
                {
                    message = "Đã cập nhật biến thể.";
                    isError = false;
                }
                else
                {
                    message = "Cập nhật biến thể thất bại.";
                    isError = true;
                }
            }

            if (!isError)
            {
                await LoadVariants();
                await Load();
                CancelVariantEdit();
            }
        }
        catch (Exception ex)
        {
            message = $"Lưu biến thể thất bại: {ex.Message}";
            isError = true;
        }
    }

    private async Task DeleteVariant(Guid id)
    {
        var result = await Swal.FireAsync(new SweetAlertOptions { Title = "Xác nhận xóa", Text = "Bạn chắc chắn muốn xóa biến thể này?", Icon = SweetAlertIcon.Warning, ShowCancelButton = true, ConfirmButtonText = "Xóa", CancelButtonText = "Hủy" });
        if (result.Dismiss != null)
        {
            return;
        }

        var ok = await productService.DeleteVariantAsync(id);
        if (ok)
        {
            message = "Đã xóa biến thể.";
            isError = false;
            await LoadVariants();
            await Load();
        }
        else
        {
            message = "Xóa biến thể thất bại.";
            isError = true;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            message = "Đang tải ảnh lên...";
            isError = false;
            StateHasChanged();

            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024); // 20MB limit
            
            // Dùng hàm upload chung không cần variantId
            var url = await productService.UploadPhotoAsync(stream, file.Name);
            
            if (!string.IsNullOrEmpty(url))
            {
                variantEditor.Anh = url;
                message = "Tải ảnh thành công!";
                isError = false;
            }
            else
            {
                message = "Tải ảnh thất bại.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"Lỗi khi tải ảnh: {ex.Message}";
            isError = true;
        }
        finally
        {
            StateHasChanged();
        }
    }

