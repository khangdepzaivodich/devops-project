@using Microsoft.AspNetCore.Components.Routing
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject blazor_frontend.Services.IAuthService AuthService

<div class="h-full flex flex-col bg-white border-r border-gray-200 text-gray-800">
    <!-- Header của Sidebar -->
    <div class="h-16 flex items-center justify-center border-b border-gray-200 shadow-sm bg-white">
        <a href="/" class="flex items-center gap-2 px-4 py-2 hover:opacity-80 transition-opacity" title="Về trang chủ">
            <img src="logo-serious1.png" alt="Serious Clothing" class="h-12 w-auto object-contain mix-blend-multiply" />
            <div class="flex flex-col justify-center leading-none">
                <div class="text-lg font-black tracking-tighter text-gray-900 uppercase">Serious</div>
                <div class="text-[8px] text-blue-600 font-black tracking-[0.2em] uppercase">Clothing</div>
            </div>
        </a>
    </div>

    <!-- Danh sách Menu Links -->
    <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
        @foreach (var item in MenuItems)
        {
            <NavLink href="@item.Url" 
                     class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-600 font-semibold text-lg !no-underline hover:bg-blue-50 hover:text-blue-600 hover:shadow-sm transition-all duration-200 group" 
                     activeClass="bg-blue-100 text-blue-700 font-bold shadow-sm" 
                     Match="NavLinkMatch.Prefix">
                <i class="@item.IconClass text-2xl text-gray-400 group-[.active]:text-blue-600 group-hover:text-blue-500 transition-colors duration-200"></i>
                <span class="group-hover:translate-x-1 transition-transform duration-200">@item.Title</span>
            </NavLink>
        }
    </nav>

    <!-- Nút Đăng xuất ở cuối -->
    <div class="p-4 border-t border-gray-200 bg-gray-50">
        <button class="flex items-center justify-center gap-3 px-4 py-3 w-full rounded-lg text-red-500 bg-white border border-red-200 
                       hover:bg-red-50 hover:text-red-700 hover:border-red-300 hover:shadow-sm transition-all duration-200 group"
                @onclick="LogoutAsync">
            <i class="ph ph-sign-out text-2xl group-hover:-translate-x-1 transition-transform duration-200"></i>
            <span class="font-semibold group-hover:-translate-x-1 transition-transform duration-200">Đăng xuất</span>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public string Role { get; set; } = "ADMIN";

    private List<MenuOption> MenuItems = new();
    protected override void OnParametersSet()
    {
        if (Role.Equals("ADMIN", StringComparison.OrdinalIgnoreCase))
        {
            MenuItems = new List<MenuOption>
            {
                new("Thống kê", "/admin/dashboard", "ph ph-chart-bar"),
                new("Đơn hàng", "/admin/orders", "ph ph-shopping-cart"),
                new("Mã giảm giá", "/admin/discounts", "ph ph-ticket"),
                new("Sản phẩm", "/admin/products", "ph ph-t-shirt"),
                new("Danh mục", "/admin/categories", "ph ph-tag"),
                new("Người dùng", "/admin/users", "ph ph-users")
            };
        }
        else if (Role.Equals("STAFF", StringComparison.OrdinalIgnoreCase))
        {
            MenuItems = new List<MenuOption>
            {
                new("Đơn hàng", "/staff/orders", "ph ph-shopping-cart"),
                new("Tư vấn khách hàng", "/staff/messages", "ph ph-chat")
            };
        }
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/account/signin", forceLoad: true);
    }

    // Một class / record nhỏ để chứa thông tin của mỗi Menu
    private record MenuOption(string Title, string Url, string IconClass);
}
