@using Microsoft.AspNetCore.Components
@inject blazor_frontend.Services.IAuthService AuthService
@inject blazor_frontend.Services.AuthState AuthState
@inject blazor_frontend.Services.ICategoryService CategoryService
@inject IJSRuntime JS
@inject NavigationManager Nav
@using blazor_frontend.Models.BackendDTOs

@code {
    private bool _mobileOpen;
    private bool _accountOpen;
    private bool _megaMenuOpen;
    private System.Threading.CancellationTokenSource? _megaMenuCts;
    private bool _isUserLoggedIn;
    private bool _isLoaded = false;
    private bool _cartDrawerOpen = false;

    [Parameter] public int CartCount { get; set; } = 0;

    private List<LoaiDanhMucDto> _loaiDanhMucs = new();
    private List<DanhMucDto> _danhMucs = new();

    protected override async Task OnInitializedAsync()
    {
        _isUserLoggedIn = AuthState.IsAuthenticated;
        if (_isUserLoggedIn) _isLoaded = true;
        AuthState.AuthStateChanged += HandleAuthStateChanged;
        
        _loaiDanhMucs = (await CategoryService.GetAllLoaiDanhMucAsync()).ToList();
        _danhMucs = (await CategoryService.GetAllAsync()).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.InitializeAsync();
            _isUserLoggedIn = AuthState.IsAuthenticated;
            _isLoaded = true;
            StateHasChanged();
        }
    }

    private async void HandleAuthStateChanged()
    {
        await InvokeAsync(() =>
        {
            _isUserLoggedIn = AuthState.IsAuthenticated;
            _isLoaded = true;
            StateHasChanged();
        });
    }

    private void ToggleMobile() => _mobileOpen = !_mobileOpen;
    private void ToggleAccount() => _accountOpen = !_accountOpen;

    private async Task ToggleMegaMenu()
    {
        _megaMenuOpen = !_megaMenuOpen;
        if (_megaMenuOpen)
        {
            _accountOpen = false;
        }
    }

    private void KeepMegaMenu()
    {
        _megaMenuCts?.Cancel();
        _megaMenuOpen = true;
    }

    private async Task CloseMegaMenu()
    {
        _megaMenuCts?.Cancel();
        _megaMenuCts = new System.Threading.CancellationTokenSource();
        try
        {
            await Task.Delay(200, _megaMenuCts.Token);
            _megaMenuOpen = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void CloseAll()
    {
        _mobileOpen = false;
        _accountOpen = false;
        _megaMenuOpen = false;
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        AuthState.Clear();
        CloseAll();
        Nav.NavigateTo("/account/signin", true);
    }

    private string headerSearchTerm = "";
    private void HandleHeaderSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(headerSearchTerm))
        {
            Nav.NavigateTo($"/products?q={Uri.EscapeDataString(headerSearchTerm)}");
            headerSearchTerm = "";
        }
    }
}

<header class="header-light sticky top-0 z-50 w-full">
    <div class="mx-auto flex max-w-[1200px] items-center justify-between px-4 py-3.5 md:px-6">

        <!-- LEFT -->
        <div class="flex items-center gap-3">
            <button type="button"
                    class="header-icon-btn-light inline-flex h-10 w-10 items-center justify-center md:hidden"
                    @onclick="ToggleMobile"
                    aria-label="Open menu">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 6h16" />
                    <path d="M4 12h16" />
                    <path d="M4 18h16" />
                </svg>
            </button>

            <a href="/" class="flex items-center gap-4 py-2" @onclick="CloseAll" aria-label="Về trang chủ">
                <img src="logo-serious1.png" alt="Serious Clothing" 
                     class="h-12 md:h-16 w-auto object-contain mix-blend-multiply transition-transform hover:scale-105" />
                <div class="flex flex-col justify-center leading-none">
                    <div class="text-2xl font-black tracking-tighter text-gray-900 uppercase">Serious</div>
                    <div class="text-[11px] text-blue-600 font-black tracking-[0.3em] uppercase mt-0.5">Clothing</div>
                </div>
            </a>
        </div>

        <!-- CENTER -->
        <nav class="hidden items-center gap-7 text-sm font-medium lg:flex">
            <div @onmouseleave="CloseMegaMenu" @onmouseenter="KeepMegaMenu">
                <button type="button" class="nav-link flex items-center gap-1 py-3 relative z-10 after:absolute after:inset-x-0 after:-bottom-6 after:h-6 after:bg-transparent" @onclick="ToggleMegaMenu">
                    Sản phẩm
                    <svg class="h-4 w-4 transition-transform duration-300" style="transform: rotate(@(_megaMenuOpen ? "180deg" : "0deg"));" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 8l5 5 5-5" />
                    </svg>
                </button>

                <div class="@(_megaMenuOpen ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none") absolute left-0 top-full w-full transition duration-200 z-0">
                    <div class="mega-menu-light">
                        <div class="mx-auto grid max-w-[1200px] grid-cols-5 divide-x divide-gray-100 py-7 px-2">
                            <div class="pr-6">
                                <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-gray-900">Tất cả</h3>
                                <ul class="space-y-1 text-[15px] font-medium text-gray-500">
                                    <li><a href="/products" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Tất cả sản phẩm</a></li>
                                    <li><a href="/category/f641efa0-571c-4876-92d1-19c985968d39/Bán chạy" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Bán chạy</a></li>
                                    <li><a href="/category/f641efa0-571c-4876-92d1-19c985968d39/Khuyến mãi" class="block border-l-2 border-transparent px-3 py-2 font-semibold text-red-500! transition-all duration-200 hover:border-red-500 hover:bg-red-50! hover:text-red-600!">Sale</a></li>
                                </ul>
                            </div>

                            @foreach (var loai in _loaiDanhMucs.Where(l => l.TenLDM != "Khác"))
                            {
                                <div class="px-6">
                                    <a href="/category/@loai.MaLDM/@Uri.EscapeDataString(loai.TenLDM)">
                                        <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-gray-900 hover:text-blue-600 transition-colors">@loai.TenLDM</h3>
                                    </a>
                                    <ul class="space-y-1 text-[15px] font-medium text-gray-500">
                                        @foreach (var danhMuc in _danhMucs.Where(d => d.MaLDM == loai.MaLDM))
                                        {
                                            <li><a href="/subcategory/@danhMuc.MaDM/@Uri.EscapeDataString(danhMuc.TenDM)" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">@danhMuc.TenDM</a></li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="pl-6 space-y-3">
                                <a href="/products/summer" class="group/card block overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                                    <img src="hero.png" class="h-28 w-full object-cover transition duration-300 group-hover/card:scale-110" alt="Summer collection" />
                                    <div class="p-3 text-sm font-bold text-gray-900">Summer</div>
                                </a>
                                <a href="/products/sport" class="group/card block overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                                    <img src="product1.jpg" class="h-28 w-full object-cover transition duration-300 group-hover/card:scale-110" alt="Sport collection" />
                                    <div class="p-3 text-sm font-bold text-gray-900">Sport</div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <a href="/products/new" class="nav-link py-3">Hàng mới</a>
            <a href="/products/best-seller" class="nav-link py-3">Bán chạy</a>
            <a href="/products/denim" class="nav-link py-3">DENIM</a>
            <a href="/products/outlet" class="nav-link py-3 text-red-500! hover:text-red-600! font-semibold">OUTLET</a>

            <div class="relative flex items-center ml-4">
                <div class="group flex items-center bg-gray-50 rounded-full px-4 py-2 border border-transparent focus-within:border-gray-200 focus-within:bg-white transition-all w-48 focus-within:w-64">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" 
                           @bind="headerSearchTerm"
                           @bind:event="oninput"
                           @onkeyup="HandleHeaderSearch"
                           placeholder="Tìm kiếm..." 
                           class="ml-2 bg-transparent border-none text-sm w-full focus:ring-0 placeholder-gray-400 font-medium" />
                </div>
            </div>
        </nav>

        <!-- RIGHT -->
        <div class="flex items-center gap-1 sm:gap-2">
            <!-- ACCOUNT -->
            <div class="relative">
                <button type="button"
                        class="flex items-center gap-2.5 px-2 py-1.5 rounded-full hover:bg-gray-100 transition-all border border-transparent hover:border-gray-200 group"
                        @onclick="ToggleAccount"
                        aria-label="Account">
                    @if (_isLoaded && _isUserLoggedIn)
                    {
                        <div class="relative">
                            <img src="@(string.IsNullOrEmpty(AuthState.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(AuthState.HoTen)}&background=random" : AuthState.AvatarUrl)" 
                                 class="w-9 h-9 rounded-full object-cover border-2 border-white shadow-sm" />
                            <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></span>
                        </div>
                        <div class="hidden md:flex flex-col items-start leading-tight pr-1">
                            <span class="text-[13px] font-bold text-gray-900 truncate max-w-[120px]">@AuthState.HoTen</span>
                            <span class="text-[9px] font-black text-blue-600 uppercase tracking-widest">@AuthState.Role</span>
                        </div>
                    }
                    else if (_isLoaded)
                    {
                        <div class="header-icon-btn-light inline-flex h-10 w-10 items-center justify-center">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21a8 8 0 0 0-16 0" />
                                <circle cx="12" cy="8" r="4" />
                            </svg>
                        </div>
                    }
                </button>

                <div class="@(_accountOpen ? "block" : "hidden") account-dropdown-light absolute right-0 mt-3 w-[300px] min-w-[300px] overflow-hidden rounded-3xl bg-white shadow-[0_20px_50px_-12px_rgba(0,0,0,0.15)] border border-gray-100 animate-fade-in-down z-50">
                    @if (_isUserLoggedIn)
                    {
                        <div class="border-b border-gray-100 px-4 py-3">
                            <div class="text-sm font-semibold text-gray-900">Tài khoản</div>
                            <div class="text-xs text-gray-500">Quản lý hồ sơ và đơn hàng</div>
                        </div>
                        <a href="/account/profile" class="block px-4 py-3 text-sm transition" @onclick="CloseAll">Profile</a>
                        
                        @if (AuthState.Role == "ADMIN")
                        {
                            <a href="/admin" class="block px-4 py-3 text-sm transition font-semibold text-blue-600" @onclick="CloseAll">Quản trị hệ thống</a>
                        }
                        else if (AuthState.Role == "STAFF")
                        {
                            <a href="/staff" class="block px-4 py-3 text-sm transition font-semibold text-blue-600" @onclick="CloseAll">Trang nhân viên</a>
                        }
                        else
                        {
                            <a href="/account/orders" class="block px-4 py-3 text-sm transition" @onclick="CloseAll">Đơn hàng của tôi</a>
                        }
                        <div class="border-t border-gray-100"></div>
                        <button class="block w-full px-4 py-3 text-left text-sm text-red-600 transition hover:bg-red-50" @onclick="LogoutAsync">Đăng xuất</button>
                    }
                    else
                    {
                        <div class="p-6 text-center bg-white">
                            <div class="mb-5 flex flex-col items-center">
                                <div class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mb-3">
                                    <svg class="w-6 h-6 text-[#0b3b72]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                    </svg>
                                </div>
                                <h4 class="text-base font-bold text-gray-900">Chào mừng bạn</h4>
                                <p class="text-[12px] text-gray-500 mt-1">Đăng nhập để theo dõi đơn hàng và nhận ưu đãi riêng biệt</p>
                            </div>
                            
                            <a href="/account/signin" 
                               class="group relative block w-full bg-white border border-gray-200 py-3 rounded-xl text-sm font-bold text-gray-900 shadow-sm transition-all hover:border-[#0b3b72] hover:shadow-md active:scale-95" 
                               @onclick="CloseAll">
                                <span class="relative z-10">Đăng nhập ngay</span>
                                <div class="absolute inset-0 bg-gray-50 opacity-0 group-hover:opacity-100 rounded-xl transition-opacity"></div>
                            </a>

                            <div class="mt-5 pt-4 border-t border-gray-50">
                                <p class="text-xs text-gray-400 font-medium">Chưa có tài khoản?</p>
                                <a href="/account/signup" 
                                   class="mt-1 inline-block text-sm font-bold text-[#0b3b72] hover:text-blue-800 transition-colors" 
                                   @onclick="CloseAll">
                                    Đăng ký thành viên
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- CART -->
            @if (_isLoaded && (!_isUserLoggedIn || (AuthState.Role != "ADMIN" && AuthState.Role != "STAFF")))
            {
                <button @onclick="() => _cartDrawerOpen = true" class="header-icon-btn-light relative inline-flex h-10 w-10 items-center justify-center" aria-label="Giỏ hàng">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                        <path d="M3 6h18" />
                        <path d="M16 10a4 4 0 0 1-8 0" />
                    </svg>
                    @if (CartCount > 0)
                    {
                        <span class="absolute right-1 top-1 flex h-4 w-4 items-center justify-center rounded-full bg-blue-600 text-[10px] font-bold text-white">@CartCount</span>
                    }
                </button>
            }
        </div>
    </div>
</header>
<CartDrawer IsOpen="_cartDrawerOpen" OnClose="() => _cartDrawerOpen = false" />
