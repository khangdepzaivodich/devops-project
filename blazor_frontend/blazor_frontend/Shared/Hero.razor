@using Microsoft.AspNetCore.Components

<section class="relative" style="padding-top:@TopOffset">
    <div class="h-72 md:h-96 lg:h-[600px] relative overflow-hidden shadow-2xl">
        <img src="@ImagePath" 
             alt="@Alt" 
             class="absolute inset-0 w-full h-full object-cover object-top filter brightness-[0.95] contrast-[1.05] grayscale-10" 
             style="object-position: top;" />
        <div class="absolute inset-0 bg-linear-to-r from-black/60 via-transparent to-transparent z-10"></div>
    </div>
</section>

@code {
    [Parameter] public string ImagePath { get; set; } = "hero22.png";
    [Parameter] public string Alt { get; set; } = "Hero image";
    [Parameter] public string TopOffset { get; set; } = "0px";
}