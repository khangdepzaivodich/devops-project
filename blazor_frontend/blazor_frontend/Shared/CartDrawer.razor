@using blazor_frontend.Models.BackendDTOs
@using blazor_frontend.Services
@using blazor_frontend.Shared
@inject IBasketService BasketService
@inject blazor_frontend.Services.IProductService ProductService
@inject blazor_frontend.Services.AuthState AuthState
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="@(IsOpen ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none") fixed inset-0 z-[100] transition-opacity duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" @onclick="OnClose"></div>

    <!-- Drawer Content -->
    <div class="@(IsOpen ? "translate-x-0" : "translate-x-full") absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl transition-transform duration-500 ease-out flex flex-col">
        
        <!-- Header -->
        <div class="flex items-center justify-between border-b border-gray-100 p-6">
            <div class="flex items-center gap-3">
                <h2 class="text-xl font-bold text-gray-900">Giỏ hàng</h2>
                <span class="rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-bold text-blue-700">@(_basket?.Items?.Count ?? 0)</span>
            </div>
            <button @onclick="OnClose" class="rounded-full p-2 hover:bg-gray-100 transition-colors">
                <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Body -->
        <div class="flex-1 overflow-y-auto p-6">
            @if (_isLoading)
            {
                <div class="flex h-full items-center justify-center">
                    <div class="h-8 w-8 animate-spin rounded-full border-4 border-blue-600 border-t-transparent"></div>
                </div>
            }
            else if (_basket?.Items?.Any() != true)
            {
                <div class="flex h-full flex-col items-center justify-center text-center">
                    <div class="mb-4 rounded-full bg-gray-50 p-6">
                        <svg class="h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Giỏ hàng trống</h3>
                    <p class="mt-2 text-sm text-gray-500">Hãy chọn cho mình những sản phẩm ưng ý nhất nhé!</p>
                    <button @onclick="GoToProducts" class="mt-6 rounded-xl bg-gray-900 px-8 py-3 text-sm font-bold text-white transition-all hover:bg-black">Mua sắm ngay</button>
                </div>
            }
            else
            {
                <div class="space-y-6">
                    @foreach (var item in _basket.Items)
                    {
                        <div class="group flex gap-4">
                            <div class="h-24 w-20 shrink-0 overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                                <img src="@item.ImageUrl" class="h-full w-full object-cover object-top" onerror="this.src='product1.jpg';" />
                            </div>
                            <div class="flex flex-1 flex-col justify-between py-1">
                                <div>
                                    @{
                                        var pp = _productById.GetValueOrDefault(item.ProductId);
                                        var vv = _variantById.GetValueOrDefault(item.ProductId);
                                    }
                                    <h4 class="text-sm font-bold text-gray-900 line-clamp-2">@(pp?.TenSP ?? item.ProductName)</h4>
                                    @if (vv != null)
                                    {
                                        <div class="mt-1 flex items-center gap-1.5">
                                            @if (!string.IsNullOrEmpty(vv.Mau))
                                            {
                                                <span class="rounded bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium text-gray-500">@vv.Mau</span>
                                            }
                                            @if (!string.IsNullOrEmpty(vv.KichCo))
                                            {
                                                <span class="rounded bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium text-gray-500">@vv.KichCo</span>
                                            }
                                        </div>
                                    }
                                    <div class="mt-1 flex items-center gap-2">
                                        <span class="text-xs font-bold text-blue-600">@item.Price.ToString("N0")₫</span>
                                        <span class="text-[10px] text-gray-400">x @item.Quantity</span>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center rounded-lg border border-gray-100 bg-gray-50">
                                        <button @onclick="() => UpdateQty(item, -1)" class="px-2 py-1 text-gray-500 hover:text-black">-</button>
                                        <span class="w-8 text-center text-xs font-bold">@item.Quantity</span>
                                        <button @onclick="() => UpdateQty(item, 1)" class="px-2 py-1 text-gray-500 hover:text-black">+</button>
                                    </div>
                                    <button @onclick="() => RemoveItem(item)" class="text-xs font-medium text-red-500 hover:underline">Xóa</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Footer -->
        @if (_basket?.Items?.Any() == true)
        {
            <div class="border-t border-gray-100 p-6 space-y-4 bg-gray-50/50">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-500">Tạm tính</span>
                    <span class="text-xl font-black text-gray-900">@_basket.Items.Sum(x => x.Price * x.Quantity).ToString("N0")₫</span>
                </div>
                <p class="text-[11px] text-gray-400">Phí vận chuyển và mã giảm giá sẽ được áp dụng tại trang thanh toán.</p>
                <div class="pt-2">
                    <button @onclick="GoToCheckout" class="w-full rounded-xl bg-[#0b3b72] py-4 text-sm font-bold text-white shadow-lg shadow-blue-900/20 transition-all hover:bg-[#082950] active:scale-95">Thanh toán</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    
    private BasketDto? _basket;
    private bool _isLoading = true;
    private Dictionary<string, SanPhamDto> _productById = new();
    private Dictionary<string, ChiTietSanPhamDto> _variantById = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen)
        {
            await LoadBasketAsync();
        }
    }

    private async Task LoadBasketAsync()
    {
        _isLoading = true;
        string? buyerId;
        if (AuthState.IsAuthenticated)
        {
            buyerId = AuthState.UserId.ToString();
        }
        else
        {
            buyerId = await JS.InvokeAsync<string?>("localStorage.getItem", "buyer_id");
        }

        if (!string.IsNullOrEmpty(buyerId))
        {
            _basket = await BasketService.GetBasketAsync(buyerId);
        }

        try
        {
            var allProducts = (await ProductService.GetAllAsync()).ToList();
            _productById = allProducts
                .SelectMany(p => p.ChiTietSanPhams.Select(v => new { VariantId = v.MaCTSP.ToString(), Product = p }))
                .ToDictionary(x => x.VariantId, x => x.Product);
            _variantById = allProducts
                .SelectMany(p => p.ChiTietSanPhams)
                .ToDictionary(v => v.MaCTSP.ToString(), v => v);
        }
        catch { }

        _isLoading = false;
        StateHasChanged();
    }

    private async Task UpdateQty(BasketItemDto item, int delta)
    {
        if (_basket == null) return;
        var newQty = item.Quantity + delta;
        if (newQty <= 0)
        {
            await RemoveItem(item);
            return;
        }
        item.Quantity = newQty;
        await BasketService.UpdateBasketAsync(_basket);
        StateHasChanged();
    }

    private async Task RemoveItem(BasketItemDto item)
    {
        if (_basket == null) return;
        _basket.Items.Remove(item);
        await BasketService.UpdateBasketAsync(_basket);
        StateHasChanged();
    }

    private async Task GoToCart()
    {
        await OnClose.InvokeAsync();
        Nav.NavigateTo("/cart");
    }

    private async Task GoToCheckout()
    {
        await OnClose.InvokeAsync();
        Nav.NavigateTo("/cart"); // Usually checkout is within cart flow
    }

    private async Task GoToProducts()
    {
        await OnClose.InvokeAsync();
        Nav.NavigateTo("/products");
    }
}
