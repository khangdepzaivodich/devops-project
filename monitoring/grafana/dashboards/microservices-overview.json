{
  "title": "Microservices Overview",
  "uid": "microservices-overview",
  "tags": ["microservices", "kubernetes", "aspnet"],
  "timezone": "Asia/Ho_Chi_Minh",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Services Up/Down",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(up{job='aspnet-services'})",
        "legendFormat": "Services Online"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "targets": [{
        "expr": "sum by(service) (rate(http_requests_received_total[5m]))",
        "legendFormat": "{{service}}"
      }]
    },
    {
      "id": 3,
      "title": "HTTP 5xx Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "targets": [{
        "expr": "sum by(service) (rate(http_requests_received_total{status_code=~'5..'}[5m])) / sum by(service) (rate(http_requests_received_total[5m])) * 100",
        "legendFormat": "{{service}}"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "id": 4,
      "title": "P95 Latency per Service (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by(service, le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
        "legendFormat": "{{service}} P95"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "title": "Pod Restarts",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(kube_pod_container_status_restarts_total{namespace=~'staging|production'}[5m]) * 60",
        "legendFormat": "{{pod}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Node CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "targets": [{
        "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Node RAM Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Container Memory Usage per Service (MB)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by(pod) (container_memory_working_set_bytes{namespace=~'staging|production', container!=''}) / 1024 / 1024",
        "legendFormat": "{{pod}}"
      }],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    },
    {
      "id": 9,
      "title": "📋 Recent Logs (Loki)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "targets": [{
        "expr": "{namespace='staging'} |= ``",
        "legendFormat": ""
      }],
      "options": {
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
